---
import {
    NAV_LINKS,
    WHATSAPP_1,
    WHATSAPP_2,
    EMAIL,
    INSTAGRAM,
    FACEBOOK,
    TIKTOK,
} from "../data/constantes";
---

<footer class="footer">
    <div class="section-line"></div>
    <div class="container footer__inner">
        <!-- Logo + tagline -->
        <div class="footer__brand">
            <a href="/" aria-label="Inicio">
                <img
                    src="/images/logo.png"
                    alt="Onda Creativa Launch 5.7"
                    height="100"
                    width="auto"
                />
            </a>
            <p class="footer__tagline">Construimos marcas con dirección.</p>
            <p class="footer__afiliados">Afiliados a:</p>
            <img
                src="/images/LogoFenalco.png"
                alt="Fenalco"
                class="footer__fenalco"
            />
        </div>

        <!-- Nav -->
        <nav class="footer__nav" aria-label="Mapa del sitio">
            <p class="footer__nav-title">Páginas</p>
            <ul>
                {
                    NAV_LINKS.map((link) => (
                        <li>
                            <a href={link.href} class="footer__nav-link">
                                {link.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>

        <!-- Contacto -->
        <div class="footer__contact">
            <p class="footer__nav-title">Contacto</p>
            <div class="footer__social">
                <!-- Grupo horizontal: Instagram + Facebook + WhatsApp -->
                <div class="footer__social-group">
                    <div class="footer__social-row">
                        <a href={INSTAGRAM} target="_blank" rel="noopener noreferrer" class="footer__social-icon-wrap" aria-label="Instagram">
                            <img src="/images/Instagram.png" alt="Instagram" class="footer__social-icon" />
                        </a>
                        <a href={FACEBOOK} target="_blank" rel="noopener noreferrer" class="footer__social-icon-wrap" aria-label="Facebook">
                            <img src="/images/Facebook.png" alt="Facebook" class="footer__social-icon" />
                        </a>
                        <a href={TIKTOK} target="_blank" rel="noopener noreferrer" class="footer__social-icon-wrap" aria-label="TikTok">
                            <img src="/images/Tiktok.png" alt="TikTok" class="footer__social-icon" />
                        </a>
                    </div>
                    <span class="footer__social-label">@ondacreativalaunch5.7</span>
                </div>
                <a href={`https://wa.me/${WHATSAPP_1.replace(/\D/g, "")}`} target="_blank" rel="noopener noreferrer" class="footer__social-link">
                    <div class="footer__social-icon-wrap">
                        <img src="/images/Whatsapp.png" alt="WhatsApp" class="footer__social-icon" />
                    </div>
                    <span class="footer__social-label">+57 321 286 5200</span>
                </a>
                <a href={`https://wa.me/${WHATSAPP_2.replace(/\D/g, "")}`} target="_blank" rel="noopener noreferrer" class="footer__social-link">
                    <div class="footer__social-icon-wrap">
                        <img src="/images/Whatsapp.png" alt="WhatsApp" class="footer__social-icon" />
                    </div>
                    <span class="footer__social-label">+57 312 544 8302</span>
                </a>
                <a href={`mailto:${EMAIL}`} class="footer__social-link">
                    <div class="footer__social-icon-wrap">
                        <img src="/images/Email.png" alt="Email" class="footer__social-icon" />
                    </div>
                    <span class="footer__social-label">{EMAIL}</span>
                </a>
            </div>
        </div>
    </div>

    <div class="footer__bottom">
        <div class="container">
            <p class="footer__copy">
                © {new Date().getFullYear()} 5.7 / Onda Creativa Launch. Todos los
                derechos reservados.
            </p>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: var(--bg-surface);
        padding-top: clamp(3rem, 6vw, 5rem);
    }

    .footer__inner {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 3rem;
        padding-bottom: clamp(2.5rem, 5vw, 4rem);
    }

    .footer__brand {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .footer__fenalco {
        max-width: 160px;
        height: auto;
        align-self: flex-start;
    }

    .footer__afiliados {
        font-size: 0.85rem;
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 0.04em;
        margin-top: 1.4rem;
        margin-bottom: -0.25rem;
    }

    .footer__tagline {
        font-size: 0.9rem;
        color: var(--text-secondary);
        max-width: 22ch;
        font-style: italic;
        margin-top: -0.5rem;
    }

    .footer__nav-title {
        font-family: var(--font-display);
        font-size: 0.8rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 1rem;
    }

    .footer__nav ul {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    .footer__nav-link {
        font-size: 0.875rem;
        color: var(--text-secondary);
        transition: color var(--t-fast) var(--ease);
    }
    .footer__nav-link:hover {
        color: var(--cyan);
    }

    .footer__social {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .footer__social-link {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        transition: transform var(--t-fast) var(--ease);
    }

    .footer__social-link:hover {
        transform: translateX(4px);
    }

    .footer__social-link:hover .footer__social-icon-wrap {
        border-color: var(--cyan);
        background: var(--bg-card-hover);
    }

    .footer__social-link:hover .footer__social-label {
        color: var(--cyan);
    }

    .footer__social-icon-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--bg-card);
        border: 1px solid var(--border);
        flex-shrink: 0;
        transition:
            border-color var(--t-fast) var(--ease),
            background var(--t-fast) var(--ease);
    }

    .footer__social-icon {
        width: 22px;
        height: 22px;
        object-fit: contain;
    }

    .footer__social-label {
        font-size: 0.875rem;
        color: var(--text-secondary);
        transition: color var(--t-fast) var(--ease);
    }

    .footer__social-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .footer__social-row {
        display: flex;
        gap: 0.6rem;
    }

    .footer__social-row .footer__social-icon-wrap:hover {
        border-color: var(--cyan);
        background: var(--bg-card-hover);
    }

    .footer__social-group:has(.footer__social-icon-wrap:hover) .footer__social-label {
        color: var(--cyan);
    }

    .footer__bottom {
        border-top: 1px solid var(--border);
        padding-block: 1.25rem;
        background: var(--bg-base);
    }

    .footer__copy {
        font-size: 0.75rem;
        color: var(--text-secondary);
        text-align: center;
    }

    @media (max-width: 768px) {
        .footer__inner {
            grid-template-columns: 1fr 1fr;
        }
        .footer__brand {
            grid-column: 1 / -1;
        }
    }

    @media (max-width: 480px) {
        .footer__inner {
            grid-template-columns: 1fr;
        }
    }
</style>
