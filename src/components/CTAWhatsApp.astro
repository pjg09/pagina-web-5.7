---
import { WHATSAPP_CTA } from "../data/constantes";

interface Props {
    label?: string;
    variant?: "primary" | "outline";
}

const { label = "Hablemos por WhatsApp", variant = "primary" } = Astro.props;
---

<a
    href={WHATSAPP_CTA}
    target="_blank"
    rel="noopener noreferrer"
    class={`btn btn--${variant} cta-whatsapp`}
    aria-label="Contactar por WhatsApp"
>
    <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
    >
