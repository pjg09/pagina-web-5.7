---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAWhatsApp from "../components/CTAWhatsApp.astro";
---

<BaseLayout
	title="Agendamientos"
	description="Agenda el espacio adecuado para resolver tus dudas, conocer nuestras soluciones y definir los siguientes pasos."
>
	<!-- SECCIÓN 1 — HERO -->
	<section class="hero" aria-label="Hero agendamientos">
		<div class="hero__bg">
			<img
				src="/images/HeroIndex.jpeg"
				alt="5.7 Onda Creativa Launch"
				class="hero__img"
				fetchpriority="high"
			/>
			<div class="hero__overlay"></div>
		</div>

		<div class="container hero__content">
			<h1 class="display display--xl hero__title reveal reveal-delay-1">
				CONVERSEMOS SOBRE TU <span class="gradient-text">PROYECTO</span>
			</h1>

			<p class="body--lg hero__sub reveal reveal-delay-2">
				Cada proyecto se encuentra en un punto diferente. Ya sea que
				representes una marca, una empresa o un proyecto musical, aquí
				puedes agendar el espacio más adecuado para resolver tus dudas,
				conocer nuestras soluciones y definir los siguientes pasos.
			</p>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 2 — TIPOS DE REUNIÓN -->
	<section class="agenda-tipos" aria-label="Elige el tipo de reunión">
		<div class="container">
			<div class="agenda-tipos__header">
				<h2 class="display display--lg agenda-tipos__titulo reveal">
					ELIGE EL TIPO DE <span class="gradient-text">REUNIÓN</span>
					QUE <span class="gradient-text">NECESITAS</span>
				</h2>
				<div class="divider reveal reveal-delay-1"></div>
				<p class="agenda-tipos__sub reveal reveal-delay-1">
					Selecciona la opción que mejor se adapte a tu situación
					actual. Cada reunión tiene un propósito diferente y está
					diseñada para ayudarte a tomar mejores decisiones para tu
					proyecto.
				</p>
			</div>

			<div class="agenda-tipos__grid">
				<!-- Empresas -->
				<div class="agenda-card-outer reveal reveal-delay-2">
					<article class="agenda-card agenda-card--empresas">
						<div class="agenda-card__image">
							<img
								src="/images/Empresas01.jpeg"
								alt="Reunión de exploración comercial para empresas y marcas"
								loading="lazy"
							/>
							<div
								class="agenda-card__image-overlay agenda-card__image-overlay--magenta"
							>
							</div>
						</div>
						<div class="agenda-card__body">
							<h3 class="display display--sm agenda-card__title">
								EMPRESAS Y MARCAS
							</h3>
							<p class="agenda-card__subtitulo">
								Conoce nuestras soluciones para marcas
							</p>
							<p class="agenda-card__text">
								Si estás evaluando fortalecer tu presencia
								digital, mejorar tu comunicación o conocer cómo
								podemos ayudarte, esta reunión es el punto de
								partida.
							</p>
							<p class="agenda-card__text">
								Durante la conversación revisaremos tu situación
								actual, resolveremos dudas y exploraremos
								posibles oportunidades de trabajo conjunto.
							</p>
							<div class="agenda-card__incluye">
								<span class="label">Incluye</span>
								<ul class="agenda-card__lista">
									<li>
										Revisión general de tu situación actual
									</li>
									<li>Espacio para resolver dudas</li>
									<li>
										Presentación de soluciones aplicables a
										tu marca
									</li>
								</ul>
							</div>
							<div class="agenda-card__info">
								<div class="agenda-card__info-item">
									<span class="agenda-card__info-label"
										>Duración</span
									>
									<span class="agenda-card__info-valor"
										>30 a 40 minutos</span
									>
								</div>
								<div class="agenda-card__info-divider"></div>
								<div class="agenda-card__info-item">
									<span class="agenda-card__info-label"
										>Modalidad</span
									>
									<span class="agenda-card__info-valor"
										>Virtual o presencial</span
									>
								</div>
								<div class="agenda-card__info-divider"></div>
								<div class="agenda-card__info-item">
									<span class="agenda-card__info-label"
										>Inversión</span
									>
									<span class="agenda-card__info-valor"
										>Sin costo</span
									>
								</div>
							</div>
							<a
								href="/agendamientos-empresas"
								class="btn agenda-card__btn"
								>Agendar reunión para mi empresa</a
							>
						</div>
					</article>
				</div>

				<!-- Artistas -->
				<div class="agenda-card-outer reveal">
					<article class="agenda-card agenda-card--artistas">
						<div class="agenda-card__image">
							<img
								src="/images/Artistas01.jpeg"
								alt="Reunión para conocer las soluciones para artistas"
								loading="lazy"
							/>
							<div class="agenda-card__image-overlay"></div>
						</div>
						<div class="agenda-card__body">
							<h3 class="display display--sm agenda-card__title">
								ARTISTAS
							</h3>
							<p class="agenda-card__subtitulo">
								Conoce nuestras soluciones para artistas
							</p>
							<p class="agenda-card__text">
								Si quieres conocer cómo trabajamos, entender qué
								servicios pueden ayudarte y resolver dudas sobre
								tu proyecto musical, esta reunión es para ti.
								Ideal para artistas que están explorando
								opciones antes de tomar una decisión.
							</p>
							<div class="agenda-card__incluye">
								<span class="label"
									><br class="br-desktop" /><br
										class="br-desktop"
									/><br class="br-desktop" /><br
										class="br-desktop"
									/>Incluye</span
								>
								<ul class="agenda-card__lista">
									<li>Espacio para resolver dudas</li>
									<li>Presentación de servicios</li>
									<li>Recomendaciones generales</li>
								</ul>
							</div>
							<div class="agenda-card__spacer"></div>
							<div class="agenda-card__info">
								<div class="agenda-card__info-item">
									<span class="agenda-card__info-label"
										>Duración</span
									>
									<span class="agenda-card__info-valor"
										>30 a 40 minutos</span
									>
								</div>
								<div class="agenda-card__info-divider"></div>
								<div class="agenda-card__info-item">
									<span class="agenda-card__info-label"
										>Modalidad</span
									>
									<span class="agenda-card__info-valor"
										>Virtual</span
									>
								</div>
								<div class="agenda-card__info-divider"></div>
								<div class="agenda-card__info-item">
									<span class="agenda-card__info-label"
										>Inversión</span
									>
									<span class="agenda-card__info-valor"
										>Sin costo</span
									>
								</div>
							</div>
							<a
								href="/agendamientos-artistas-comercial"
								class="btn agenda-card__btn"
								>Quiero conocer las soluciones para artistas</a
							>
						</div>
					</article>
				</div>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 3 — ASESORÍA ESTRATÉGICA PARA ARTISTAS -->
	<section
		class="asesoria-sec"
		aria-label="Asesoría estratégica para artistas"
	>
		<div class="asesoria-header">
			<div class="asesoria-body">
				<div class="container">
					<div class="asesoria-body__intro reveal">
						<h2 class="display display--lg asesoria-titulo">
							ASESORÍA ESTRATÉGICA PARA <span
								class="gradient-text">ARTISTAS</span
							>
						</h2>
						<p class="asesoria-desc">
							Una sesión personalizada diseñada para analizar tu
							proyecto musical, identificar oportunidades de
							mejora y brindarte una orientación estratégica más
							profunda según tus objetivos actuales.
						</p>
						<p class="asesoria-desc">
							Esta sesión requiere preparación previa y está
							dirigida a artistas que desean recibir una
							evaluación más detallada de su situación actual.
						</p>
					</div>
					<div class="asesoria-listas reveal reveal-delay-1">
						<div class="asesoria-lista">
							<p class="asesoria-lista__titulo">
								Durante la sesión trabajaremos en:
							</p>
							<ul>
								<li>Revisión de tu proyecto artístico</li>
								<li>Análisis de presencia digital</li>
								<li>Evaluación de posicionamiento actual</li>
								<li>
									Identificación de oportunidades de
									crecimiento
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>

			<div class="asesoria-foto reveal">
				<img
					src="/images/InternaArtistas04.jpeg"
					alt="Asesoría estratégica para artistas"
					loading="lazy"
				/>
				<div class="asesoria-foto__border"></div>
			</div>
		</div>

		<div class="asesoria-pricing">
			<div class="container asesoria-pricing__inner">
				<div class="asesoria-pricing__item reveal">
					<span class="asesoria-pricing__label">Duración</span>
					<span class="asesoria-pricing__valor">60 minutos</span>
				</div>
				<div class="asesoria-pricing__divider"></div>
				<div class="asesoria-pricing__item reveal reveal-delay-1">
					<span class="asesoria-pricing__label">Modalidad</span>
					<span class="asesoria-pricing__valor">Virtual</span>
				</div>
				<div class="asesoria-pricing__divider"></div>
				<div class="asesoria-pricing__item reveal reveal-delay-2">
					<span class="asesoria-pricing__label">Inversión</span>
					<div class="asesoria-pricing__precios">
						<span>Colombia: <strong>$150.000 COP</strong></span>
						<span>Otros países: <strong>50 USD</strong></span>
					</div>
				</div>
			</div>
		</div>

		<div class="asesoria-cta">
			<div class="container asesoria-cta__inner">
				<a
					href="/agendamientos-artistas-estrategica"
					class="btn asesoria-cta__btn"
					>Solicitar asesoría estratégica</a
				>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 4 — DUDA SOBRE QUÉ OPCIÓN ELEGIR -->
	<section class="duda-cierre" aria-label="¿No sabes qué opción elegir?">
		<div class="container duda-cierre__inner">
			<h2 class="display display--lg duda-cierre__titulo reveal">
				¿NO ESTÁS SEGURO DE QUÉ <span class="gradient-text">OPCIÓN</span
				> ELEGIR?
			</h2>
			<p class="duda-cierre__texto reveal reveal-delay-1">
				Si tienes dudas sobre cuál reunión es la más adecuada para tu
				situación, escríbenos por WhatsApp y te orientaremos antes de
				agendar.
			</p>
			<div class="reveal reveal-delay-2">
				<CTAWhatsApp label="Hablar por WhatsApp" />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* HERO */
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		align-items: flex-end;
		padding-top: 140px; /* header height — prevents content from going behind fixed nav on short viewports */
		padding-bottom: clamp(4rem, 8vw, 7rem);
		overflow: hidden;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
	}

	.hero__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background: none;
	}

	.hero__content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
		max-width: 780px;
		margin-left: 60%;
	}

	@media (max-width: 1500px) {
		.hero__content {
			margin-left: 45%;
		}
	}

	@media (max-width: 1280px) {
		.hero__content {
			margin-left: 38%;
		}
		.hero__title {
			line-height: 0.95;
		}
	}

	@media (max-width: 768px) {
		.hero__content {
			margin-left: 0;
			max-width: 100%;
		}
	}

	.hero__title {
		line-height: 0.92;
	}

	.hero__sub {
		color: var(--text-high);
		font-size: 1.8rem;
		max-width: 52ch;
		font-weight: 500;
	}

	/* TIPOS DE REUNIÓN */
	.agenda-tipos {
		padding-block: var(--section-gap);
		background: var(--bg-base);
	}

	.agenda-tipos__header {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
		margin-bottom: clamp(3rem, 6vw, 4.5rem);
	}

	.agenda-tipos__titulo {
		line-height: 0.95;
		max-width: 20ch;
	}

	.agenda-tipos__header .divider {
		margin-bottom: 0;
	}

	.agenda-tipos__sub {
		color: var(--text-dim);
		font-size: clamp(1.58rem, 2.4vw, 1.78rem);
		font-weight: 500;
		letter-spacing: 0.02em;
		max-width: 48ch;
	}

	.agenda-tipos__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.agenda-card-outer {
		position: relative;
		isolation: isolate;
		display: flex;
		flex-direction: column;
	}
	.agenda-card-outer::before {
		content: "";
		position: absolute;
		inset: -6.5px;
		border-radius: calc(var(--radius-lg) + 6.5px);
		background: linear-gradient(135deg, var(--cyan), var(--magenta));
		z-index: -1;
		opacity: 0.25;
		filter: blur(1px);
		transition: opacity var(--t-med) var(--ease);
	}
	.agenda-card-outer:hover::before {
		opacity: 0.55;
	}

	.agenda-card {
		flex: 1;
		display: flex;
		flex-direction: column;
		background: var(--bg-card);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.agenda-card__image {
		position: relative;
		aspect-ratio: 4/3;
		overflow: hidden;
	}
	.agenda-card__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s var(--ease);
	}
	.agenda-card:hover .agenda-card__image img {
		transform: scale(1.04);
	}
	.agenda-card__image-overlay {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(to bottom, transparent 40%, var(--bg-card) 100%),
			linear-gradient(135deg, var(--cyan-dim) 0%, transparent 70%);
	}
	.agenda-card__image-overlay--magenta {
		background:
			linear-gradient(to bottom, transparent 40%, var(--bg-card) 100%),
			linear-gradient(135deg, var(--magenta-dim) 0%, transparent 70%);
	}

	.agenda-card__body {
		flex: 1;
		display: flex;
		flex-direction: column;
		padding: clamp(1.5rem, 3vw, 2rem);
		gap: 0.75rem;
	}

	.agenda-card__title {
		color: var(--cyan);
		letter-spacing: 0.15em;
	}

	.agenda-card__subtitulo {
		color: var(--text-secondary);
		font-size: clamp(1.21rem, 1.8vw, 1.32rem);
		font-weight: 600;
		font-style: italic;
	}

	.agenda-card__text {
		color: var(--text-secondary);
		font-size: clamp(1.31rem, 2vw, 1.48rem);
		line-height: 1.6;
		font-weight: 500;
	}

	.agenda-card__incluye {
		display: flex;
		flex-direction: column;
		margin-top: 0.25rem;
	}
	.agenda-card__incluye .label {
		margin-bottom: 0.75rem;
	}

	.agenda-card__lista {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.agenda-card__lista li {
		font-size: clamp(1.31rem, 2vw, 1.48rem);
		color: var(--text-secondary);
		padding-left: 1.2rem;
		position: relative;
		font-weight: 500;
	}
	.agenda-card__lista li::before {
		content: "·";
		position: absolute;
		left: 0;
		color: var(--cyan);
		font-weight: 700;
	}
	.agenda-card--empresas .agenda-card__lista li::before {
		color: var(--magenta);
	}

	.agenda-card__spacer {
		display: none;
	}

	@media (min-width: 901px) {
		.agenda-card--artistas .agenda-card__spacer {
			display: block;
			height: 1.64rem;
		}
	}

	.agenda-card__info {
		display: grid;
		grid-template-columns: 1fr auto 1fr auto 1fr;
		align-items: center;
		margin-top: 0.75rem;
		margin-bottom: 1.5rem;
		padding-top: 1.25rem;
		border-top: 1px solid var(--border);
	}

	.agenda-card__info-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4rem;
		text-align: center;
		padding: 0.5rem;
	}

	.agenda-card__info-divider {
		width: 2px;
		height: 56px;
		background: linear-gradient(to bottom, var(--cyan), var(--magenta));
		border-radius: 2px;
		flex-shrink: 0;
		margin-inline: 0.75rem;
	}

	.agenda-card__info-label {
		font-family: var(--font-display);
		font-size: clamp(0.72rem, 1vw, 0.8rem);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	.agenda-card__info-valor {
		font-size: clamp(1.05rem, 1.5vw, 1.2rem);
		font-weight: 700;
		color: var(--text-primary);
		line-height: 1.2;
	}

	.agenda-card__btn {
		margin-top: auto;
		align-self: center;
		max-width: 100%;
		white-space: normal;
		text-align: center;
		background: #fff;
		color: #000;
		border: none;
	}
	.agenda-card__btn:hover {
		background: #fff;
		border: 2px solid var(--cyan);
		transform: translateY(-2px);
		background-clip: text;
		-webkit-background-clip: text;
		color: transparent;
		background-image: linear-gradient(90deg, var(--cyan), var(--magenta));
	}

	@media (max-width: 900px) {
		.agenda-tipos__grid {
			grid-template-columns: 1fr;
		}

		.br-desktop {
			display: none;
		}
	}

	@media (max-width: 600px) {
		.agenda-card__info {
			grid-template-columns: 1fr;
			justify-items: center;
			gap: 0.5rem;
		}
		.agenda-card__info-divider {
			width: 120px;
			height: 2px;
			background: linear-gradient(90deg, var(--cyan), var(--magenta));
			margin: 0.5rem auto;
		}
	}

	/* ASESORÍA ESTRATÉGICA */
	.asesoria-sec {
		background: var(--bg-base);
	}

	.asesoria-header {
		display: grid;
		grid-template-columns: 55% 45%;
		min-height: 80vh;
		border-top: 1px solid var(--border);
	}

	.asesoria-body {
		background: var(--bg-surface);
		display: flex;
		align-items: center;
		padding-block: clamp(4rem, 8vw, 7rem);
	}

	.asesoria-body__intro {
		margin-bottom: 3rem;
	}

	.asesoria-titulo {
		font-size: clamp(1.8rem, 4vw, 3.4rem);
		line-height: 1.05;
		margin-top: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.asesoria-desc {
		font-size: clamp(1.58rem, 2.4vw, 1.78rem);
		color: var(--text-secondary);
		line-height: 1.75;
		max-width: 58ch;
	}
	.asesoria-desc + .asesoria-desc {
		margin-top: 1.25rem;
	}

	.asesoria-listas {
		display: grid;
		grid-template-columns: 1fr;
		max-width: 36rem;
	}

	.asesoria-foto {
		width: 100%;
		height: 100%;
		min-height: 500px;
		overflow: hidden;
		position: relative;
	}

	.asesoria-foto img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 30%;
		display: block;
	}

	.asesoria-foto__border {
		position: absolute;
		top: 0;
		left: 0;
		bottom: 0;
		width: 6px;
		background: linear-gradient(to bottom, var(--cyan), var(--magenta));
		opacity: 0.25;
		filter: blur(1px);
		z-index: 2;
	}

	.asesoria-lista__titulo {
		font-family: var(--font-body);
		font-weight: 700;
		color: var(--cyan);
		margin-bottom: 1rem;
		font-size: clamp(1.32rem, 1.9vw, 1.44rem);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		padding-bottom: 0.6rem;
		border-bottom: 1px solid var(--border);
	}

	.asesoria-lista ul {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		padding: 0;
		list-style: none;
	}

	.asesoria-lista ul li {
		font-size: clamp(1.58rem, 2.4vw, 1.78rem);
		color: var(--text-secondary);
		padding-left: 1.4rem;
		position: relative;
		line-height: 1.55;
	}

