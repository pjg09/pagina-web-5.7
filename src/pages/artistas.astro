---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAWhatsApp from "../components/CTAWhatsApp.astro";
import {
	WHATSAPP_CTA,
	CALENDLY_ARTISTAS,
	MP_ASESORIA_ARTISTAS,
} from "../data/constantes";
---

<BaseLayout
	title="Artistas"
	description="Estés empezando, lanzando o buscando crecer, aquí encuentras la estructura y el impulso que tu música necesita."
>
	<!-- SECCIÓN 1 — HERO -->
	<section class="hero" aria-label="Hero artistas">
		<div class="hero__bg">
			<img
				src="/images/HeroArtistas.jpeg"
				alt="Artistas musicales con dirección"
				class="hero__img"
				fetchpriority="high"
			/>
			<div class="hero__overlay"></div>
		</div>

		<div class="container hero__content">
			<h1 class="display display--xl hero__title reveal reveal-delay-1">
				TU <span class="gradient-text">MÚSICA</span> NECESITA<br />
				MÁS QUE TALENTO,<br />
				NECESITA <span class="gradient-text">DIRECCIÓN</span>
			</h1>

			<p class="body--lg hero__sub reveal reveal-delay-2">
				Estés empezando, lanzando o buscando crecer, aquí encuentras la
				estructura y el impulso que tu música necesita.
			</p>

			<div class="hero__ctas reveal reveal-delay-3">
				<a href="#soluciones" class="btn hero__btn">
					Ver cómo impulsar mi música
				</a>
				<a
					href={CALENDLY_ARTISTAS}
					target="_blank"
					rel="noopener noreferrer"
					class="btn hero__btn"
				>
					Agendar asesoría estratégica
				</a>
			</div>

			<a
				href="#soluciones"
				class="hero__scroll reveal reveal-delay-4"
				aria-label="Ver soluciones para artistas"
			>
				<span>Conocer más</span>
				<svg
					width="16"
					height="16"
					viewBox="0 0 16 16"
					fill="none"
					aria-hidden="true"
				>
					<path
						d="M8 3v10M3 8l5 5 5-5"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</a>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 2 — INTRO -->
	<section
		class="intro"
		id="soluciones"
		aria-label="Estructura para artistas"
	>
		<div class="container intro__inner">
			<h2 class="display display--lg intro__titulo reveal reveal-delay-1">
				ESTRUCTURA REAL PARA HACER<br />
				QUE TU <span class="gradient-text">MÚSICA</span> AVANCE
			</h2>

			<div class="intro__divider reveal reveal-delay-2"></div>

			<p class="intro__cta frase-destacada reveal reveal-delay-3">
				<em>Aquí es donde entramos...</em>
			</p>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 3 — DIFERENTES ETAPAS -->
	<section class="etapas-sec" aria-label="Diferentes etapas">
		<div class="container">
			<div class="etapas__header reveal">
				<span class="label">El patrón que se repite</span>
				<h2 class="display display--lg etapas__titulo">
					DIFERENTES ETAPAS,<br />LOS MISMOS <span
						class="gradient-text">BLOQUEOS</span
					>
				</h2>
			</div>

			<div class="etapas__foto reveal">
				<img
					src="/images/InternaArtistas01.jpeg"
					alt="Artistas en diferentes etapas"
					loading="lazy"
				/>
			</div>

			<div class="etapas__intro reveal reveal-delay-1">
				<p>
					No todos los proyectos musicales están en el mismo punto.
					Algunos artistas están dando sus primeros pasos, otros ya
					cuentan con equipo y algunos trabajan desde estructuras más
					avanzadas como disqueras o equipos de management.
				</p>
				<p>
					Sin embargo, los obstáculos suelen repetirse: falta de
					dirección, problemas de ejecución y dificultades para
					convertir el trabajo realizado en crecimiento real.
				</p>
			</div>

			<div class="etapas__grid">
				<div class="etapa-card reveal">
					<div class="etapa-card__header">
						<img
							src="/images/ArtistasEmergentes.png"
							alt=""
							class="etapa-card__icono"
							aria-hidden="true"
						/>
						<h3 class="display display--sm etapa-card__titulo">
							Artistas<br />emergentes
						</h3>
					</div>
					<ul class="etapa-card__lista">
						<li>Sacan música, pero nadie la escucha</li>
						<li>No saben cómo lanzar correctamente</li>
						<li>Todo depende de "subir contenido"</li>
					</ul>
				</div>
				<div class="etapa-card reveal reveal-delay-1">
					<div class="etapa-card__header">
						<img
							src="/images/ArtistasCrecimiento.png"
							alt=""
							class="etapa-card__icono"
							aria-hidden="true"
						/>
						<h3 class="display display--sm etapa-card__titulo">
							Artistas en<br />crecimiento
						</h3>
					</div>
					<ul class="etapa-card__lista">
						<li>Tienen equipo, pero no hay dirección clara</li>
						<li>Invierten, pero no ven resultados consistentes</li>
						<li>Su contenido no escala</li>
					</ul>
				</div>
				<div class="etapa-card reveal reveal-delay-2">
					<div class="etapa-card__header">
						<img
							src="/images/EquiposDisqueras.png"
							alt=""
							class="etapa-card__icono"
							aria-hidden="true"
						/>
						<h3 class="display display--sm etapa-card__titulo">
							Equipos y<br />disqueras
						</h3>
					</div>
					<ul class="etapa-card__lista">
						<li>Falta de ejecución operativa</li>
						<li>Necesidad de apoyo externo confiable</li>
					</ul>
				</div>
			</div>

			<p class="etapas__cierre frase-destacada reveal">
				<em>SIN ESTRUCTURA, EL TALENTO SE ESTANCA</em>
			</p>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 4 — SERVICIOS -->
	<section class="servicios-sec" aria-label="Servicios para artistas">
		<!-- Header sección 4 -->
		<div class="servicios-header">
			<div class="servicios-header__banner">
				<img
					src="/images/InternaArtistas03.jpeg"
					alt=""
					class="servicios-header__banner-img"
					loading="lazy"
					aria-hidden="true"
				/>
			</div>
			<div class="container">
				<div class="reveal">
					<h2 class="display display--lg">
						NUESTROS <span class="gradient-text">SERVICIOS</span>
					</h2>
				</div>
				<p class="pivote__texto reveal">
					<span class="gradient-text"
						>Estrategia, ejecución y crecimiento para tu música</span
					>
				</p>
			</div>
		</div>

		<!-- 4B — SERVICIO 1: LANZAMIENTO (dirección B) -->
		<div class="servicio-bloque servicio-bloque--b reveal">
			<div class="container sb-b">
				<div class="sb-b-meta">
					<span class="servicio-num">01</span>
				</div>
				<div class="sb-b-head">
					<h3 class="display display--md servicio-titulo">
						LANZAMIENTO Y ESTRATEGIA DIGITAL
					</h3>
					<p class="servicio-desc">
						Diseñamos y ejecutamos lanzamientos musicales según tu
						etapa: desde artistas emergentes hasta equipos y
						disqueras que necesitan apoyo operativo.
					</p>
					<a
						href={CALENDLY_ARTISTAS}
						target="_blank"
						rel="noopener noreferrer"
						class="btn servicio-btn"
						>Quiero lanzar mi música correctamente</a
					>
				</div>
				<div class="sb-b-items">
					<div class="sb-b-item">
						<div class="sb-b-item__header">
							<img
								src="/images/EstrategiaLanzamiento.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>Estrategia de<br />lanzamiento</span
							>
						</div>
						<p class="servicio-item__desc">
							Creamos el plan completo para lanzar tu tema con
							dirección y sentido.
						</p>
					</div>
					<div class="sb-b-item">
						<div class="sb-b-item__header">
							<img
								src="/images/PlaneacionCampanas.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>Planeación de<br />campañas musicales</span
							>
						</div>
						<p class="servicio-item__desc">
							Organizamos cada acción del lanzamiento para generar
							impacto real.
						</p>
					</div>
				</div>
			</div>
		</div>

		<!-- 4C — SERVICIO 2: VISIBILIDAD (dirección C) -->
		<div class="servicio-bloque servicio-bloque--c reveal">
			<div class="container">
				<div class="sb-c-header">
					<span class="servicio-num">02</span>
					<div class="sb-c-ht">
						<h3 class="display display--md servicio-titulo">
							VISIBILIDAD DIGITAL Y PLATAFORMAS
						</h3>
						<p class="servicio-desc">
							Llevamos tu música a más personas con estrategias
							enfocadas en alcance, tráfico y posicionamiento
							real.
						</p>
					</div>
				</div>
				<div class="sb-c-grid sb-c-grid--2">
					<div class="sb-c-card-outer">
						<div class="sb-c-card">
							<div class="sb-b-item__header">
								<img
									src="/images/CampanasYoutube.png"
									alt=""
									class="sb-b-item__icono"
									aria-hidden="true"
								/>
								<span class="servicio-item__nombre"
									>Campañas de<br />promoción en YouTube</span
								>
							</div>
							<p class="servicio-item__desc">
								Impulsamos tus videos con vistas segmentadas o
								latinas para aumentar alcance real.
							</p>
						</div>
					</div>
					<div class="sb-c-card-outer">
						<div class="sb-c-card">
							<div class="sb-b-item__header">
								<img
									src="/images/EstrategiasCrecimiento.png"
									alt=""
									class="sb-b-item__icono"
									aria-hidden="true"
								/>
								<span class="servicio-item__nombre"
									>Estrategias de<br />crecimiento en redes</span
								>
							</div>
							<p class="servicio-item__desc">
								Desarrollamos acciones para que tu contenido
								crezca con intención y consistencia.
							</p>
						</div>
					</div>
					<div class="sb-c-card-outer">
						<div class="sb-c-card">
							<div class="sb-b-item__header">
								<img
									src="/images/CampanasInfluencers.png"
									alt=""
									class="sb-b-item__icono"
									aria-hidden="true"
								/>
								<span class="servicio-item__nombre"
									>Campañas con<br />influencers TikTok & IG</span
								>
							</div>
							<p class="servicio-item__desc">
								Conectamos tu música con creadores que
								amplifican tu visibilidad.
							</p>
						</div>
					</div>
					<div class="sb-c-card-outer">
						<div class="sb-c-card">
							<div class="sb-b-item__header">
								<img
									src="/images/PromocionTematicas.png"
									alt=""
									class="sb-b-item__icono"
									aria-hidden="true"
								/>
								<span class="servicio-item__nombre"
									>Promoción en<br />páginas temáticas</span
								>
							</div>
							<p class="servicio-item__desc">
								Publicamos tu tema en plataformas que ya tienen
								audiencia activa en tu género.
							</p>
						</div>
					</div>
				</div>
				<div class="sb-c-cta">
					<a
						href={CALENDLY_ARTISTAS}
						target="_blank"
						rel="noopener noreferrer"
						class="btn servicio-btn"
						>Quiero que mi música llegue a más personas</a
					>
				</div>
			</div>
		</div>

		<!-- 4D — SERVICIO 3: PRODUCCIÓN (dirección B) -->
		<div class="servicio-bloque servicio-bloque--b reveal">
			<div class="container sb-b">
				<div class="sb-b-meta">
					<span class="servicio-num">03</span>
				</div>
				<div class="sb-b-head">
					<h3 class="display display--md servicio-titulo">
						PRODUCCIÓN AUDIOVISUAL
					</h3>
					<p class="servicio-desc">
						Fortalecemos tu imagen artística con contenido visual
						profesional, tanto para artistas independientes como
						para proyectos más estructurados.
					</p>
					<a
						href={CALENDLY_ARTISTAS}
						target="_blank"
						rel="noopener noreferrer"
						class="btn servicio-btn"
						>Quiero elevar mi proyecto visual</a
					>
				</div>
				<div class="sb-b-items">
					<div class="sb-b-item">
						<div class="sb-b-item__header">
							<img
								src="/images/ProduccionVideo.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>Producción de<br />video oficial</span
							>
						</div>
						<p class="servicio-item__desc">
							Creamos videos que representan tu música con calidad
							y dirección.
						</p>
					</div>
					<div class="sb-b-item">
						<div class="sb-b-item__header">
							<img
								src="/images/ProduccionMusical.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>Producción<br />musical</span
							>
						</div>
						<p class="servicio-item__desc">
							Trabajamos el sonido de tus temas para lograr un
							resultado profesional.
						</p>
					</div>
					<div class="sb-b-item">
						<div class="sb-b-item__header">
							<img
								src="/images/Fotografia.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>Fotografía<br />profesional</span
							>
						</div>
						<p class="servicio-item__desc">
							Construimos una imagen visual sólida para tu
							proyecto.
						</p>
					</div>
					<div class="sb-b-item">
						<div class="sb-b-item__header">
							<img
								src="/images/ContenidoVisual.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>Contenido visual<br />para redes</span
							>
						</div>
						<p class="servicio-item__desc">
							Generamos piezas listas para publicar y conectar con
							tu audiencia.
						</p>
					</div>
				</div>
			</div>
		</div>

		<!-- 4E — SERVICIO 4: MEDIOS (dirección C) -->
		<div class="servicio-bloque servicio-bloque--c reveal">
			<div class="container">
				<div class="sb-c-header">
					<span class="servicio-num">04</span>
					<div class="sb-c-ht">
						<h3 class="display display--md servicio-titulo">
							MEDIOS Y PRESENTACIONES
						</h3>
						<p class="servicio-desc">
							Abrimos espacios de exposición para artistas en
							crecimiento y en consolidación que necesitan
							presencia real en escenarios y medios.
						</p>
					</div>
				</div>
				<div class="sb-c-grid sb-c-grid--3">
					<div class="sb-c-card-outer">
						<div class="sb-c-card">
							<div class="sb-b-item__header">
								<img
									src="/images/GiraMedios.png"
									alt=""
									class="sb-b-item__icono"
									aria-hidden="true"
								/>
								<span class="servicio-item__nombre"
									>Gira de<br />medios</span
								>
							</div>
							<p class="servicio-item__desc">
								Gestionamos entrevistas y apariciones para darte
								exposición.
							</p>
						</div>
					</div>
					<div class="sb-c-card-outer">
						<div class="sb-c-card">
							<div class="sb-b-item__header">
								<img
									src="/images/Presentaciones.png"
									alt=""
									class="sb-b-item__icono"
									aria-hidden="true"
								/>
								<span class="servicio-item__nombre"
									>Presentaciones<br />en vivo</span
								>
							</div>
							<p class="servicio-item__desc">
								Te conectamos con escenarios donde tu música
								puede crecer como discotecas, colegios, eventos
								y actividades comunitarias.
							</p>
						</div>
					</div>
					<div class="sb-c-card-outer">
						<div class="sb-c-card">
							<div class="sb-b-item__header">
								<img
									src="/images/Cines.png"
									alt=""
									class="sb-b-item__icono"
									aria-hidden="true"
								/>
								<span class="servicio-item__nombre"
									>Publicidad en<br />salas de cine</span
								>
							</div>
							<p class="servicio-item__desc">
								Proyectamos tu video musical en pantallas de
								alto impacto.
							</p>
						</div>
					</div>
				</div>
				<div class="sb-c-cta">
					<a
						href={CALENDLY_ARTISTAS}
						target="_blank"
						rel="noopener noreferrer"
						class="btn servicio-btn"
						>Quiero más exposición para mi música</a
					>
				</div>
			</div>
		</div>

		<!-- 4F — FRASE FINAL -->
		<div class="cierre-sec">
			<div class="container cierre-sec__inner">
				<p class="display display--lg cierre-sec__texto reveal">
					<span class="gradient-text"
						>SI TU MÚSICA YA EXISTE, ES MOMENTO DE HACERLA CRECER</span
					>
				</p>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 5 — ASESORÍA ESTRATÉGICA -->
	<section
		class="asesoria-sec"
		aria-label="Asesoría estratégica para artistas"
	>
		<!-- 5A — DESCRIPCIÓN + IMAGEN -->
		<div class="asesoria-header">
			<!-- Texto -->
			<div class="asesoria-body">
				<div class="container">
					<div class="asesoria-body__intro reveal">
						<h2 class="display display--lg asesoria-titulo">
							ASESORÍA ESTRATÉGICA PARA <span
								class="gradient-text">ARTISTAS</span
							><br />QUE QUIEREN <span class="gradient-text"
								>AVANZAR</span
							>
						</h2>
						<p class="asesoria-desc">
							Sesión personalizada diseñada para analizar tu
							proyecto musical, evaluar tu situación actual y
							brindarte una orientación estratégica clara para el
							crecimiento de tu carrera.
						</p>
					</div>
					<div class="asesoria-listas reveal reveal-delay-1">
						<div class="asesoria-lista">
							<p class="asesoria-lista__titulo">
								Durante esta sesión trabajaremos en:
							</p>
							<ul>
								<li>Revisión de tu proyecto artístico</li>
								<li>Análisis de presencia digital</li>
								<li>Evaluación de tu posicionamiento actual</li>
								<li>
									Identificación de oportunidades de
									crecimiento
								</li>
							</ul>
						</div>
						<div class="asesoria-lista">
							<p
								class="asesoria-lista__titulo asesoria-lista__titulo--segunda"
							>
								Incluye:
							</p>
							<ul>
								<li>Diagnóstico previo del proyecto</li>
								<li>
									Orientación estratégica durante la sesión
								</li>
								<li>
									Informe posterior con recomendaciones
									generales <span class="asesoria-nota"
										>(Costo adicional, se indica en reunión)</span
									>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>

			<!-- Imagen como bloque fotográfico independiente -->
			<div class="asesoria-foto reveal">
				<img
					src="/images/InternaArtistas04.jpeg"
					alt="Asesoría estratégica para artistas"
					loading="lazy"
				/>
				<div class="asesoria-foto__border"></div>
			</div>
		</div>

		<!-- 5B — PRICING -->
		<div class="asesoria-pricing">
			<div class="container asesoria-pricing__inner">
				<div class="asesoria-pricing__item reveal">
					<span class="asesoria-pricing__label">Duración</span>
					<span class="asesoria-pricing__valor">60 minutos</span>
				</div>
				<div class="asesoria-pricing__divider"></div>
				<div class="asesoria-pricing__item reveal reveal-delay-1">
					<span class="asesoria-pricing__label">Modalidad</span>
					<span class="asesoria-pricing__valor">Virtual</span>
				</div>
				<div class="asesoria-pricing__divider"></div>
				<div class="asesoria-pricing__item reveal reveal-delay-2">
					<span class="asesoria-pricing__label">Inversión</span>
					<div class="asesoria-pricing__precios">
						<span>Colombia: <strong>$150.000 COP</strong></span>
						<span>Otro país: <strong>60 USD</strong></span>
					</div>
				</div>
			</div>
		</div>

		<!-- 5C — GUÍA DE PASOS -->
		<div class="asesoria-pasos">
			<div class="container">
				<!-- Paso 1: Pago -->
				<div class="asesoria-paso reveal">
					<div class="asesoria-paso__num">01</div>
					<div class="asesoria-paso__contenido">
						<h3 class="display display--sm asesoria-paso__titulo">
							REALIZA TU PAGO
						</h3>
						<p class="asesoria-paso__desc">
							Haz clic en el botón y completa el pago de tu
							asesoría a través de WOMPI (Pasarela de pagos de
							Bancolombia) utilizando cualquiera de los métodos
							disponibles en la plataforma.
						</p>
						<button
							type="button"
							class="btn asesoria-paso__btn"
							id="btnAbrirCondiciones"
						>
							Pagar asesoría estratégica
						</button>
					</div>
				</div>

				<!-- Paso 2: Correo -->
				<div class="asesoria-paso reveal">
					<div class="asesoria-paso__num">02</div>
					<div class="asesoria-paso__contenido">
						<h3 class="display display--sm asesoria-paso__titulo">
							REVISA TU CORREO ELECTRÓNICO
						</h3>
						<p class="asesoria-paso__desc">
							Una vez confirmado el pago, recibirás un correo con
							un enlace personal para continuar el proceso de
							agendamiento. Si no encuentras el mensaje en tu
							bandeja principal, revisa también las carpetas de
							spam, promociones o correo no deseado.
						</p>
						<div class="asesoria-paso__aviso">
							<span
								>Si después de unos minutos no lo has recibido,
								puedes contactarnos por WhatsApp para ayudarte.</span
							>
						</div>
					</div>
				</div>

				<!-- Paso 3: Formulario (ilustrativo) -->
				<div class="asesoria-paso reveal">
					<div class="asesoria-paso__num">03</div>
					<div class="asesoria-paso__contenido">
						<h3 class="display display--sm asesoria-paso__titulo">
							COMPLETA EL FORMULARIO PREVIO
						</h3>
						<p class="asesoria-paso__desc">
							Antes de la sesión necesitaremos conocer mejor tu
							proyecto para preparar la reunión de manera
							adecuada.<br /><br />Deberás completar la siguiente
							información:
						</p>
						<div class="asesoria-form asesoria-form--preview">
							<div class="asesoria-form__campo">
								<span class="asesoria-form__label"
									>Nombre artístico</span
								>
								<div class="asesoria-form__input-preview">
									Tu nombre artístico
								</div>
							</div>
							<div class="asesoria-form__campo">
								<span class="asesoria-form__label"
									>Redes sociales</span
								>
								<div class="asesoria-form__input-preview">
									Usuarios de Instagram / TikTok
								</div>
							</div>
							<div class="asesoria-form__campo">
								<span class="asesoria-form__label"
									>Plataformas musicales</span
								>
								<div class="asesoria-form__input-preview">
									Usuarios de YouTube / Spotify
								</div>
							</div>
							<div class="asesoria-form__campo">
								<span class="asesoria-form__label"
									>Descripción del proyecto</span
								>
								<div
									class="asesoria-form__input-preview asesoria-form__input-preview--tall"
								>
									País, género, tiempo de carrera, logros o
									avances, entre otros
								</div>
							</div>
							<div class="asesoria-form__campo">
								<span class="asesoria-form__label"
									>Objetivos actuales</span
								>
								<div class="asesoria-form__input-preview">
									¿Qué quieres lograr con tu música?
								</div>
							</div>
						</div>
					</div>
				</div>

				<!-- Paso 4: Agendamiento -->
				<div class="asesoria-paso reveal">
					<div class="asesoria-paso__num">04</div>
					<div class="asesoria-paso__contenido">
						<h3 class="display display--sm asesoria-paso__titulo">
							AGENDA TU SESIÓN
						</h3>
						<p class="asesoria-paso__desc">
							Una vez enviado el formulario, serás redirigido
							automáticamente al calendario para seleccionar la
							fecha y hora disponible que mejor se adapte a ti.
						</p>
					</div>
				</div>

				<!-- Paso 5: Confirmación -->
				<div class="asesoria-paso reveal">
					<div class="asesoria-paso__num">05</div>
					<div class="asesoria-paso__contenido">
						<h3 class="display display--sm asesoria-paso__titulo">
							RECIBE TU CONFIRMACIÓN
						</h3>
						<p class="asesoria-paso__desc">
							Después de agendar tu sesión recibirás un correo de
							confirmación con:
						</p>
						<ul class="asesoria-paso__lista">
							<li>Fecha y hora de la reunión</li>
							<li>Enlace de acceso a la videollamada</li>
							<li>
								Información necesaria para participar en la
								sesión
							</li>
						</ul>
						<p class="asesoria-paso__desc">
							Nuestro equipo también recibirá la notificación para
							preparar tu asesoría.
						</p>
					</div>
				</div>
			</div>
		</div>

		<!-- 5D — NORMATIVAS -->
		<div class="asesoria-normativas">
			<div class="container">
				<div class="asesoria-normativas__inner-outer reveal">
					<div class="asesoria-normativas__inner">
						<h3
							class="display display--sm asesoria-normativas__titulo"
						>
							Condiciones <br />de la asesoría
						</h3>
						<ul class="asesoria-normativas__lista">
							<li>
								La asesoría es individual y no transferible.
							</li>
							<li>
								La sesión debe agendarse después de realizar
								el pago.
							</li>
							<li>
								El tiempo máximo de espera es de 10 minutos.
							</li>
							<li>
								Cancelaciones o reprogramaciones deben
								solicitarse con mínimo 12 horas de
								anticipación.
							</li>
						</ul>
					</div>
				</div>
			</div>
		</div>

		<!-- 5E — CTA CIERRE -->
		<div class="asesoria-cierre">
			<div class="container asesoria-cierre__inner">
				<h2 class="display display--lg asesoria-cierre__titulo reveal">
					<span class="gradient-text"
						>SI TE TOMAS TU MÚSICA<br />EN SERIO, ESTE ES EL
						SIGUIENTE PASO</span
					>
				</h2>
				<div class="reveal reveal-delay-2">
					<CTAWhatsApp />
				</div>
			</div>
		</div>
	</section>

	<!-- MODAL: Condiciones de la asesoría -->
	<div
		class="modal-overlay"
		id="modalCondiciones"
		aria-modal="true"
		role="dialog"
		aria-labelledby="modalCondicionesTitle"
	>
		<div class="modal-card">
			<button
				type="button"
				class="modal-close"
				id="btnCerrarModal"
				aria-label="Cerrar">✕</button
			>

			<h2 class="modal-title" id="modalCondicionesTitle">
				CONDICIONES DE LA ASESORÍA
			</h2>

			<div class="modal-divider"></div>

			<ul class="modal-conditions">
				<li>La asesoría es individual y no transferible.</li>
				<li>
					El agendamiento debe realizarse después de completar el
					proceso de pago.
				</li>
				<li>
					El tiempo máximo de espera el día de la sesión será de 10
					minutos. Pasado este tiempo se considerará inasistencia.
				</li>
				<li>
					Las cancelaciones o solicitudes de reprogramación deberán
					realizarse con mínimo 12 horas de anticipación.
				</li>
				<li>
					En caso de inasistencia sin previo aviso dentro del tiempo
					establecido, la inversión realizada no será reembolsable.
				</li>
			</ul>

			<label class="modal-accept" for="modalAcceptCheck">
				<input type="checkbox" id="modalAcceptCheck" />
				<span class="modal-accept__label"
					>He leído y acepto las condiciones de la asesoría.</span
				>
			</label>

			<a
				href={MP_ASESORIA_ARTISTAS}
				target="_blank"
				rel="noopener noreferrer"
				class="modal-btn-continuar"
				id="modalBtnContinuar"
				aria-disabled="true"
			>
				CONTINUAR
			</a>
		</div>
	</div>
</BaseLayout>

