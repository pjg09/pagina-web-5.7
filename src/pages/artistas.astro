---
import BaseLayout from "../layouts/BaseLayout.astro";
import { WHATSAPP_CTA, CALENDLY_ARTISTAS } from "../data/constantes";
---

<BaseLayout
	title="Artistas"
	description="Estés empezando, lanzando o buscando crecer, aquí encuentras la estructura y el impulso que tu música necesita."
>
	<!-- SECCIÓN 1 — HERO -->
	<section class="hero" aria-label="Hero artistas">
		<div class="hero__bg">
			<img
				src="/images/HeroArtistas.jpeg"
				alt="Artistas musicales con dirección"
				class="hero__img"
				fetchpriority="high"
			/>
			<div class="hero__overlay"></div>
		</div>

		<div class="container hero__content">
			<h1 class="display display--xl hero__title reveal reveal-delay-1">
				TU <span class="gradient-text">MÚSICA</span> NECESITA<br />
				MÁS QUE TALENTO,<br />
				NECESITA <span class="gradient-text">DIRECCIÓN</span>
			</h1>

			<p class="body--lg hero__sub reveal reveal-delay-2">
				Estés empezando, lanzando o buscando crecer, aquí encuentras la
				estructura y el impulso que tu música necesita.
			</p>

			<div class="hero__ctas reveal reveal-delay-3">
				<a href="#soluciones" class="btn hero__btn">
					Ver cómo impulsar mi música
				</a>
				<a
					href={CALENDLY_ARTISTAS}
					target="_blank"
					rel="noopener noreferrer"
					class="btn hero__btn"
				>
					Agendar asesoría estratégica
				</a>
			</div>

			<a
				href="#soluciones"
				class="hero__scroll reveal reveal-delay-4"
				aria-label="Ver soluciones para artistas"
			>
				<span>Conocer más</span>
				<svg
					width="16"
					height="16"
					viewBox="0 0 16 16"
					fill="none"
					aria-hidden="true"
				>
					<path
						d="M8 3v10M3 8l5 5 5-5"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</a>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 2 — INTRO -->
	<section
		class="intro"
		id="soluciones"
		aria-label="Estructura para artistas"
	>
		<div class="container intro__inner">
			<h2 class="display display--lg intro__titulo reveal reveal-delay-1">
				ESTRUCTURA REAL PARA HACER<br />
				QUE TU <span class="gradient-text">MÚSICA</span> AVANCE
			</h2>

			<div class="intro__divider reveal reveal-delay-2"></div>

			<p class="intro__texto reveal reveal-delay-2">
				No todos los artistas están en el mismo punto. Algunos están
				comenzando, otros ya tienen equipo y otros trabajan desde una
				disquera. Pero todos tienen algo en común: si no hay ejecución
				real, la música no avanza.
			</p>

			<p class="intro__cta reveal reveal-delay-3">
				<em>Aquí es donde entramos.</em>
			</p>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 3 — ETAPAS + SERVICIOS -->
	<section class="servicios-sec" aria-label="Servicios para artistas">
		<!-- 3A — BLOQUEOS POR ETAPA -->
		<div class="etapas">
			<div class="container">
				<div class="etapas__header reveal">
					<span class="label">El patrón que se repite</span>
					<h2 class="display display--lg etapas__titulo">
						DIFERENTES ETAPAS,<br />LOS MISMOS <span
							class="gradient-text">BLOQUEOS</span
						>
					</h2>
				</div>

				<div class="etapas__grid">
					<div class="etapa-card reveal">
						<h3 class="display display--sm etapa-card__titulo">
							Artistas emergentes
						</h3>
						<ul class="etapa-card__lista">
							<li>Sacan música, pero nadie la escucha</li>
							<li>No saben cómo lanzar correctamente</li>
							<li>Todo depende de "subir contenido"</li>
						</ul>
					</div>
					<div class="etapa-card reveal reveal-delay-1">
						<h3 class="display display--sm etapa-card__titulo">
							Artistas en crecimiento
						</h3>
						<ul class="etapa-card__lista">
							<li>Tienen equipo, pero no hay dirección clara</li>
							<li>
								Invierten, pero no ven resultados consistentes
							</li>
							<li>Su contenido no escala</li>
						</ul>
					</div>
					<div class="etapa-card reveal reveal-delay-2">
						<h3 class="display display--sm etapa-card__titulo">
							Equipos y disqueras
						</h3>
						<ul class="etapa-card__lista">
							<li>Falta de ejecución operativa</li>
							<li>Procesos desordenados en lanzamientos</li>
							<li>Necesidad de apoyo externo confiable</li>
						</ul>
					</div>
				</div>
			</div>
		</div>

		<!-- 3B — FRASE PIVOTE -->
		<div class="pivote">
			<div class="container">
				<p class="pivote__texto reveal">
					<span class="gradient-text"
						>ESTO ES LO QUE HACEMOS CUANDO HAY DIRECCIÓN:</span
					>
				</p>
			</div>
		</div>

		<!-- 3C — SERVICIO 1: LANZAMIENTO (texto + imagen) -->
		<div class="servicio-bloque servicio-bloque--imagen-derecha">
			<div class="container servicio-bloque__inner">
				<div class="servicio-bloque__texto reveal">
					<span class="servicio-num">01</span>
					<h3 class="display display--md servicio-titulo">
						LANZAMIENTO Y ESTRATEGIA DIGITAL
					</h3>
					<p class="servicio-desc">
						Diseñamos y ejecutamos lanzamientos musicales según tu
						etapa: desde artistas emergentes hasta equipos y
						disqueras que necesitan apoyo operativo.
					</p>
					<div class="servicio-items">
						<div class="servicio-item">
							<span class="servicio-item__nombre"
								>Estrategias de lanzamiento</span
							>
							<p class="servicio-item__desc">
								Creamos el plan completo para lanzar tu tema con
								dirección y sentido.
							</p>
						</div>
						<div class="servicio-item">
							<span class="servicio-item__nombre"
								>Planeación de campañas musicales</span
							>
							<p class="servicio-item__desc">
								Organizamos cada acción del lanzamiento para
								generar impacto real.
							</p>
						</div>
					</div>
					<a
						href={CALENDLY_ARTISTAS}
						target="_blank"
						rel="noopener noreferrer"
						class="btn servicio-btn"
						>Quiero lanzar mi música correctamente</a
					>
				</div>
				<div class="servicio-bloque__imagen reveal reveal-delay-2">
					<img
						src="/images/InternaArtistas01.jpeg"
						alt="Lanzamiento musical con estrategia"
						loading="lazy"
					/>
				</div>
			</div>
		</div>

		<!-- 3D — SERVICIO 2: VISIBILIDAD (ancho completo) -->
		<div class="servicio-bloque servicio-bloque--full">
			<div class="container">
				<div class="servicio-full__header reveal">
					<span class="servicio-num">02</span>
					<h3 class="display display--md servicio-titulo">
						VISIBILIDAD DIGITAL Y PLATAFORMAS
					</h3>
					<p class="servicio-desc servicio-desc--wide">
						Llevamos tu música a más personas con estrategias
						enfocadas en alcance, tráfico y posicionamiento real.
					</p>
				</div>
				<div class="servicio-full__grid">
					<div class="servicio-item servicio-item--card reveal">
						<span class="servicio-item__nombre"
							>Campañas de promoción en YouTube</span
						>
						<p class="servicio-item__desc">
							Impulsamos tus videos con vistas segmentadas o
							latinas para aumentar alcance real.
						</p>
					</div>
					<div
						class="servicio-item servicio-item--card reveal reveal-delay-1"
					>
						<span class="servicio-item__nombre"
							>Estrategias de crecimiento en redes sociales</span
						>
						<p class="servicio-item__desc">
							Desarrollamos acciones para que tu contenido crezca
							con intención y consistencia.
						</p>
					</div>
					<div
						class="servicio-item servicio-item--card reveal reveal-delay-2"
					>
						<span class="servicio-item__nombre"
							>Campañas con influencers en TikTok e Instagram</span
						>
						<p class="servicio-item__desc">
							Conectamos tu música con creadores que amplifican tu
							visibilidad.
						</p>
					</div>
					<div
						class="servicio-item servicio-item--card reveal reveal-delay-3"
					>
						<span class="servicio-item__nombre"
							>Promoción en páginas temáticas y urbanas</span
						>
						<p class="servicio-item__desc">
							Publicamos tu tema en plataformas que ya tienen
							audiencia activa en tu género.
						</p>
					</div>
				</div>
				<div class="servicio-full__cta reveal">
					<a
						href={CALENDLY_ARTISTAS}
						target="_blank"
						rel="noopener noreferrer"
						class="btn servicio-btn"
						>Quiero que mi música llegue a más personas</a
					>
				</div>
			</div>
		</div>

		<!-- 3E — SERVICIO 3: PRODUCCIÓN (imagen + texto) -->
		<div class="servicio-bloque servicio-bloque--imagen-izquierda">
			<div class="container servicio-bloque__inner">
				<div class="servicio-bloque__imagen reveal">
					<img
						src="/images/InternaArtistas02.jpeg"
						alt="Producción audiovisual para artistas"
						loading="lazy"
					/>
				</div>
				<div class="servicio-bloque__texto reveal reveal-delay-1">
					<span class="servicio-num">03</span>
					<h3 class="display display--md servicio-titulo">
						PRODUCCIÓN AUDIOVISUAL
					</h3>
					<p class="servicio-desc">
						Fortalecemos tu imagen artística con contenido visual
						profesional, tanto para artistas independientes como
						para proyectos más estructurados.
					</p>
					<div class="servicio-items">
						<div class="servicio-item">
							<span class="servicio-item__nombre"
								>Producción de video oficial</span
							>
							<p class="servicio-item__desc">
								Creamos videos que representan tu música con
								calidad y dirección.
							</p>
						</div>
						<div class="servicio-item">
							<span class="servicio-item__nombre"
								>Producción musical</span
							>
							<p class="servicio-item__desc">
								Trabajamos el sonido de tus temas para lograr un
								resultado profesional.
							</p>
						</div>
						<div class="servicio-item">
							<span class="servicio-item__nombre"
								>Fotografía profesional</span
							>
							<p class="servicio-item__desc">
								Construimos una imagen visual sólida para tu
								proyecto.
							</p>
						</div>
						<div class="servicio-item">
							<span class="servicio-item__nombre"
								>Contenido visual para redes</span
							>
							<p class="servicio-item__desc">
								Generamos piezas listas para publicar y conectar
								con tu audiencia.
							</p>
						</div>
					</div>
					<a
						href={CALENDLY_ARTISTAS}
						target="_blank"
						rel="noopener noreferrer"
						class="btn servicio-btn"
						>Quiero elevar mi proyecto visual</a
					>
				</div>
			</div>
		</div>

		<!-- 3F — SERVICIO 4: MEDIOS (ancho completo) -->
		<div class="servicio-bloque servicio-bloque--full">
			<div class="container">
				<div class="servicio-full__header reveal">
					<span class="servicio-num">04</span>
					<h3 class="display display--md servicio-titulo">
						MEDIOS Y PRESENTACIONES
					</h3>
					<p class="servicio-desc servicio-desc--wide">
						Abrimos espacios de exposición para artistas en
						crecimiento y en consolidación que necesitan presencia
						real en escenarios y medios.
					</p>
				</div>
				<div class="servicio-full__grid servicio-full__grid--3col">
					<div class="servicio-item servicio-item--card reveal">
						<span class="servicio-item__nombre">Gira de medios</span
						>
						<p class="servicio-item__desc">
							Gestionamos entrevistas y apariciones para darte
							exposición.
						</p>
					</div>
					<div
						class="servicio-item servicio-item--card reveal reveal-delay-1"
					>
						<span class="servicio-item__nombre"
							>Presentaciones en discotecas, colegios y eventos
							comunitarios</span
						>
						<p class="servicio-item__desc">
							Te conectamos con escenarios donde tu música puede
							crecer.
						</p>
					</div>
					<div
						class="servicio-item servicio-item--card reveal reveal-delay-2"
					>
						<span class="servicio-item__nombre"
							>Publicidad en salas de cine</span
						>
						<p class="servicio-item__desc">
							Proyectamos tu video musical en pantallas de alto
							impacto.
						</p>
					</div>
				</div>
				<div class="servicio-full__cta reveal">
					<a
						href={CALENDLY_ARTISTAS}
						target="_blank"
						rel="noopener noreferrer"
						class="btn servicio-btn"
						>Quiero más exposición para mi música</a
					>
				</div>
			</div>
		</div>

		<!-- 3G — FRASE FINAL -->
		<div class="cierre-sec">
			<div class="container">
				<p class="cierre-sec__texto reveal">
					<span class="gradient-text"
						>SI TU MÚSICA YA EXISTE, ES MOMENTO<br />DE HACERLA
						CRECER DE VERDAD</span
					>
				</p>
			</div>
		</div>
	</section>

	<div class="section-line"></div>
</BaseLayout>

<style>
	/* HERO */
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		align-items: flex-end;
		padding-top: 140px;
		padding-bottom: clamp(4rem, 8vw, 7rem);
		overflow: hidden;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
	}

	.hero__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to left,
			rgba(8, 8, 16, 0.1) 0%,
			rgba(8, 8, 16, 0.7) 50%,
			rgba(8, 8, 16, 0.88) 100%
		);
	}

	.hero__content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
		max-width: 55%;
		margin-left: 8%;
		margin-right: auto;
	}

	@media (max-width: 768px) {
		.hero__content {
			max-width: 100%;
		}
	}

	.hero__title {
		line-height: 1.3;
	}

	.hero__sub {
		color: var(--text-high);
		font-size: 1.35rem;
		max-width: 48ch;
		font-weight: 500;
	}

	@media (max-width: 768px) {
		.hero__sub {
			font-size: 1.1rem;
		}
	}

	.hero__ctas {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.5rem;
	}

	.hero__btn {
		background: #fff;
		color: #000;
		border: none;
	}

	.hero__btn:hover {
		background: #fff;
		border: 2px solid var(--cyan);
		transform: translateY(-2px);
		background-clip: text;
		-webkit-background-clip: text;
		color: transparent;
		background-image: linear-gradient(90deg, var(--cyan), var(--magenta));
	}

	.hero__scroll {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-dim);
		margin-top: 1rem;
		transition: color var(--t-fast) var(--ease);
	}

	.hero__scroll:hover {
		color: var(--cyan);
	}

	/* INTRO */
	.intro {
		padding-block: var(--section-gap);
		background: var(--bg-surface);
	}

	.intro__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.75rem;
		max-width: 1060px;
		margin-inline: auto;
	}

	.intro__titulo {
		line-height: 1.05;
	}

	.intro__divider {
		width: 60px;
		height: 2px;
		background: linear-gradient(90deg, var(--cyan), var(--magenta));
		border-radius: 2px;
	}

	.intro__texto {
		font-size: clamp(1.05rem, 2vw, 1.25rem);
		color: var(--text-secondary);
		line-height: 1.8;
		font-weight: 400;
		max-width: 68ch;
	}

	.intro__cta {
		font-family: var(--font-display);
		font-size: clamp(1.3rem, 3vw, 1.9rem);
		letter-spacing: 0.06em;
		background: linear-gradient(
			135deg,
			#00cfdd 0%,
			#0a2fa8 35%,
			#e0004f 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	/* SECCIÓN 3 — SERVICIOS */
	.servicios-sec {
		background: var(--bg-base);
	}

	/* ETAPAS */
	.etapas {
		padding-block: var(--section-gap);
		background: var(--bg-base);
	}

	.etapas__header {
		text-align: center;
		margin-bottom: clamp(2.5rem, 5vw, 4rem);
	}

	.etapas__titulo {
		margin-top: 0.75rem;
		line-height: 1.05;
	}

	.etapas__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.etapa-card {
		background: var(--bg-card);
		border: 1px solid rgba(0, 194, 255, 0.25);
		border-radius: var(--radius-lg);
		padding: clamp(1.5rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		transition: border-color var(--t-med) var(--ease);
	}

	.etapa-card:hover {
		border-color: var(--cyan);
	}

	.etapa-card__titulo {
		color: var(--cyan);
		font-size: clamp(1.1rem, 2vw, 1.4rem);
	}

	.etapa-card__lista {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.etapa-card__lista li {
		font-size: 1rem;
		color: var(--text-secondary);
		padding-left: 1.2rem;
		position: relative;
		line-height: 1.5;
	}

	.etapa-card__lista li::before {
		content: "·";
		position: absolute;
		left: 0;
		color: #e0004f;
		font-weight: 700;
	}

	/* FRASE PIVOTE */
	.pivote {
		padding-block: clamp(3rem, 6vw, 5rem);
		background: var(--bg-surface);
		border-top: 1px solid var(--border);
		border-bottom: 1px solid var(--border);
	}

	.pivote__texto {
		font-family: var(--font-display);
		font-size: clamp(1.4rem, 3.5vw, 2.4rem);
		letter-spacing: 0.06em;
		text-align: center;
	}

	/* BLOQUES DE SERVICIO */
	.servicio-bloque {
		padding-block: var(--section-gap);
	}

	.servicio-bloque--imagen-derecha,
	.servicio-bloque--imagen-izquierda {
		background: var(--bg-base);
	}

	.servicio-bloque--full {
		background: var(--bg-surface);
	}

	.servicio-bloque__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(3rem, 6vw, 6rem);
		align-items: center;
	}

	.servicio-bloque__imagen {
		border-radius: var(--radius-lg);
		overflow: hidden;
		aspect-ratio: 4/3;
	}

	.servicio-bloque__imagen img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.servicio-bloque__texto {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.servicio-num {
		font-family: var(--font-display);
		font-size: 4rem;
		line-height: 1;
		background: linear-gradient(
			135deg,
			#00cfdd 0%,
			#0a2fa8 35%,
			#e0004f 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.servicio-titulo {
		color: var(--text-primary);
		line-height: 1.1;
	}

	.servicio-desc {
		font-size: 1.05rem;
		color: var(--text-secondary);
		line-height: 1.7;
	}

	.servicio-desc--wide {
		max-width: 65ch;
		margin-inline: auto;
		text-align: center;
	}

	.servicio-items {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		border-left: 2px solid rgba(0, 194, 255, 0.3);
		padding-left: 1.25rem;
	}

	.servicio-item__nombre {
		display: block;
		font-weight: 700;
		color: var(--text-primary);
		font-size: 0.95rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		margin-bottom: 0.25rem;
	}

	.servicio-item__desc {
		font-size: 0.9rem;
		color: var(--text-secondary);
		line-height: 1.6;
	}

	/* Servicio full width */
	.servicio-full__header {
