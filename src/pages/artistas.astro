	.modal-accept input[type="checkbox"] {
		appearance: none;
		-webkit-appearance: none;
		width: 18px;
		height: 18px;
		min-width: 18px;
		border: 1.5px solid rgba(0, 194, 255, 0.45);
		border-radius: 4px;
