</style>

<script is:inline>
	(function () {
		var overlay = document.getElementById("modalCondiciones");
		var btnAbrir = document.getElementById("btnAbrirCondiciones");
		var btnCerrar = document.getElementById("btnCerrarModal");
		var checkbox = document.getElementById("modalAcceptCheck");
		var btnContinuar = document.getElementById("modalBtnContinuar");

		function openModal() {
			overlay.classList.add("is-open");
			document.body.style.overflow = "hidden";
			checkbox.checked = false;
			btnContinuar.classList.remove("is-enabled");
			btnContinuar.setAttribute("aria-disabled", "true");
		}

		function closeModal() {
			overlay.classList.remove("is-open");
			document.body.style.overflow = "";
		}

		btnAbrir.addEventListener("click", openModal);
		btnCerrar.addEventListener("click", closeModal);

		checkbox.addEventListener("change", function () {
			if (checkbox.checked) {
				btnContinuar.classList.add("is-enabled");
				btnContinuar.setAttribute("aria-disabled", "false");
			} else {
				btnContinuar.classList.remove("is-enabled");
				btnContinuar.setAttribute("aria-disabled", "true");
			}
		});

		overlay.addEventListener("click", function (e) {
			if (e.target === overlay) closeModal();
		});

		document.addEventListener("keydown", function (e) {
			if (e.key === "Escape" && overlay.classList.contains("is-open"))
				closeModal();
		});
	})();
</script>
