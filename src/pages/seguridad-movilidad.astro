---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAWhatsApp from "../components/CTAWhatsApp.astro";
import { WHATSAPP_CTA } from "../data/constantes.ts";
---

<BaseLayout
	title="Seguridad y Movilidad VIP"
	description="Protección y logística de movilidad para artistas y ejecutivos que necesitan operar con discreción, orden y respaldo."
>
	<!-- SECCIÓN 1 — HERO -->
	<section class="hero" aria-label="Hero Seguridad y Movilidad VIP">
		<div class="hero__bg">
			<img
				src="/images/HeroSeguridad.jpeg"
				alt="Seguridad y movilidad VIP para artistas y empresarios"
				class="hero__img"
				fetchpriority="high"
			/>
			<div class="hero__overlay"></div>
		</div>

		<div class="container hero__content">
			<div class="hero__text">
				<h1
					class="display display--xl hero__title reveal reveal-delay-2"
				>
					MOVILIDAD,<br />
					SEGURIDAD Y<br />
					CONTROL A LA<br />
					ALTURA DE
					<span class="gradient-text">TU NIVEL</span>
				</h1>
				<p class="body--lg hero__sub reveal reveal-delay-3">
					Soluciones profesionales para artistas, equipos y
					empresarios que requieren protección, organización y
					presencia en cada desplazamiento o evento.
				</p>
				<div class="hero__ctas reveal reveal-delay-4">
					<a href="#servicios" class="btn hero__btn">
						Coordinar servicio
					</a>
					<CTAWhatsApp label="Hablar por WhatsApp" />
				</div>
				<a
					href="#servicios"
					class="hero__scroll reveal"
					aria-label="Ver servicios de seguridad y movilidad"
				>
					<span>Conocer más</span>
					<svg
						width="16"
						height="16"
						viewBox="0 0 16 16"
						fill="none"
						aria-hidden="true"
					>
						<path
							d="M8 3v10M3 8l5 5 5-5"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"></path>
					</svg>
				</a>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 2 — PROPÓSITO -->
	<section class="proposito" aria-label="Por qué importa">
		<div class="container proposito__inner">
			<h2
				class="display display--xl proposito__titulo reveal reveal-delay-1"
			>
				NO SE TRATA SOLO DE MOVERSE. <br class="br-desktop" />SE TRATA
				DE
				<span class="gradient-text">HACERLO BIEN</span>
			</h2>
			<div class="divider"></div>
			<div class="proposito__body">
				<p class="body--lg proposito__p reveal reveal-delay-2">
					Cuando hay exposición, eventos o figuras públicas
					involucradas, la logística no puede improvisarse. Se
					necesita estructura, seguridad y control en cada movimiento.
				</p>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 3 — EL PROBLEMA -->
	<section class="problema" aria-label="El problema">
		<div class="problema__split">
			<div class="problema__imagen reveal">
				<img
					src="/images/InternaSeguridad01.jpeg"
					alt="Seguridad en eventos y movilidad"
					loading="lazy"
				/>
			</div>
			<div class="problema__content reveal reveal-delay-1">
				<div class="container">
					<h2 class="display display--lg problema__titulo">
						CUANDO NO HAY<br />
						ESTRUCTURA,<br />
						TODO SE <span class="gradient-text">EXPONE</span>
					</h2>
					<p class="problema__intro">
						Muchos artistas, equipos y empresarios enfrentan:
					</p>
					<ul class="problema__lista">
						<li>
							<span class="problema__lista-num">01</span>Falta de
							seguridad en eventos
						</li>
						<li>
							<span class="problema__lista-num">02</span>Traslados
							sin planificación ni respaldo
						</li>
						<li>
							<span class="problema__lista-num">03</span>Riesgos
							en exposición pública
						</li>
						<li>
							<span class="problema__lista-num">04</span>Logística
							improvisada
						</li>
						<li>
							<span class="problema__lista-num">05</span>Mala
							experiencia en movilidad
						</li>
					</ul>
				</div>
			</div>
		</div>
		<div class="problema__cierre">
			<div class="container">
				<p class="problema__mensaje frase-destacada reveal">
					<span
						>LA EXPOSICIÓN SIN CONTROL ES UN RIESGO.<br />
						EL NIVEL TAMBIÉN SE PROTEGE</span
					>
				</p>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 4 — SOLUCIONES -->
	<section
		class="soluciones-seg"
		id="servicios"
		aria-label="Soluciones de seguridad y movilidad"
	>
		<div class="container soluciones-seg__header">
			<h2 class="display display--lg soluciones-seg__titulo reveal">
				SOLUCIONES PARA MOVERTE CON <span class="gradient-text"
					>SEGURIDAD</span
				> Y <span class="gradient-text">NIVEL</span>
			</h2>
			<div class="divider reveal reveal-delay-1"></div>
			<p class="soluciones-seg__sub reveal reveal-delay-1">
				Esto es lo que coordinamos para que cada movimiento esté bajo
				control:
			</p>
		</div>

		<div class="soluciones-seg__imagen reveal reveal-delay-2">
			<img
				src="/images/InternaSeguridad02.jpeg"
				alt="Movilidad y seguridad ejecutiva"
				loading="lazy"
			/>
		</div>

		<div class="container">
			<div class="soluciones-seg__grid">
				<div class="soluciones-seg__card-outer reveal">
					<article class="soluciones-seg__card">
						<div class="sb-b-item__header">
							<img
								src="/images/Escudo.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>SEGURIDAD<br />VIP</span
							>
						</div>
						<p class="servicio-item__desc">
							Protección profesional para artistas, empresarios y
							equipos en eventos, desplazamientos y exposiciones
							públicas.
						</p>
					</article>
				</div>

				<div class="soluciones-seg__card-outer reveal reveal-delay-1">
					<article class="soluciones-seg__card">
						<div class="sb-b-item__header">
							<img
								src="/images/Armor.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>VEHÍCULOS BLINDADOS<br />Y CONVENCIONALES</span
							>
						</div>
						<p class="servicio-item__desc">
							Opciones de transporte seguras, discretas y
							adaptadas al nivel de exposición.
						</p>
					</article>
				</div>

				<div class="soluciones-seg__card-outer reveal reveal-delay-2">
					<article class="soluciones-seg__card">
						<div class="sb-b-item__header">
							<img
								src="/images/Van.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>VANS EJECUTIVAS<br />Y BUSES</span
							>
						</div>
						<p class="servicio-item__desc">
							Movilidad organizada para equipos de trabajo, giras
							y producción.
						</p>
					</article>
				</div>

				<div class="soluciones-seg__card-outer reveal reveal-delay-3">
					<article class="soluciones-seg__card">
						<div class="sb-b-item__header">
							<img
								src="/images/Bus.png"
								alt=""
								class="sb-b-item__icono"
								aria-hidden="true"
							/>
							<span class="servicio-item__nombre"
								>LIMOBUSES PARA<br />EVENTOS ESPECIALES</span
							>
						</div>
						<p class="servicio-item__desc">
							Experiencias de alto impacto para eventos,
							lanzamientos y celebraciones.
						</p>
					</article>
				</div>
			</div>

			<div class="soluciones-seg__cta reveal">
				<a
					href={WHATSAPP_CTA}
					target="_blank"
					rel="noopener noreferrer"
					class="btn soluciones-seg__btn"
					>Coordinar servicio ejecutivo</a
				>
			</div>

			<div class="soluciones-seg__frase reveal">
				<h2 class="display display--lg soluciones-seg__frase-titulo">
					<span class="gradient-text"
						>CÓMO TE MUEVES TAMBIÉN DEFINE TU NIVEL</span
					>
				</h2>
			</div>
		</div>
	</section>

	<div class="section-line"></div>
</BaseLayout>

<style>
	/* HERO */
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		align-items: flex-end;
		padding-top: 140px;
		padding-bottom: clamp(4rem, 8vw, 7rem);
		overflow: hidden;
		background: var(--bg-base);
	}

	.hero__bg {
		position: absolute;
		inset: 0;
	}

	.hero__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: right center;
		display: block;
	}

	/* El overlay oscurece el lado izquierdo (sujeto visual) y el borde inferior.
	   El área derecha de la imagen ya es oscura de forma natural. */
	.hero__overlay {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(
				to right,
				rgba(8, 8, 16, 0.75) 0%,
				rgba(8, 8, 16, 0.45) 45%,
				rgba(8, 8, 16, 0.05) 70%
			),
			linear-gradient(to top, rgba(8, 8, 16, 0.65) 0%, transparent 38%);
	}

	.hero__content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}

	.hero__text {
		max-width: 55%;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.25rem;
	}

	/* Línea de acento táctica sobre el label */
	.hero__rule {
		width: 2.5rem;
		height: 1px;
		background: var(--cyan);
		opacity: 0.65;
	}

	.hero__title {
		line-height: 0.92;
	}

	.hero__sub {
		color: var(--text-high);
		font-size: 1.8rem;
		max-width: 42ch;
		font-weight: 400;
	}

	.hero__ctas {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}

	.hero__ctas .hero__btn,
	.hero__ctas :global(.cta-whatsapp) {
		min-width: 15rem;
		justify-content: center;
	}

	.hero__ctas :global(.cta-whatsapp) {
		font-size: 1.1rem;
		padding: 0.85rem 2rem;
	}

	.hero__btn {
		background: #fff;
		color: #000;
		border: 1.5px solid transparent;
		transition:
			background 0.22s,
			color 0.22s,
			border-color 0.22s;
	}

	.hero__btn:hover {
		background: transparent;
		color: var(--cyan);
		border-color: var(--cyan);
	}

	.hero__scroll {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-mid);
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		text-decoration: none;
		margin-top: 0.25rem;
		transition: color 0.2s;
	}

	.hero__scroll:hover {
		color: var(--cyan);
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {
		.hero__content {
			align-items: flex-start;
		}

		.hero__text {
			max-width: 100%;
		}

		.hero__overlay {
			background: linear-gradient(
				to top,
				rgba(8, 8, 16, 0.88) 0%,
				rgba(8, 8, 16, 0.55) 55%,
				rgba(8, 8, 16, 0.25) 100%
			);
		}
	}

	@media (max-width: 540px) {
		.hero__ctas {
			flex-direction: column;
		}

		.hero__ctas .hero__btn,
		.hero__ctas :global(.cta-whatsapp) {
			width: 100%;
			justify-content: center;
		}
	}

	/* PROPÓSITO */
	.proposito {
		padding: clamp(5rem, 10vw, 9rem) 0;
		background: var(--bg-surface);
	}

	.proposito__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
	}

	.proposito__titulo {
		line-height: 0.9;
	}

	.proposito__inner .divider {
		margin-top: 1.5rem;
	}

	.proposito__body {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		max-width: 50.3rem;
		text-align: justify;
	}

	.proposito__p {
		color: var(--text-dim);
		font-size: clamp(1.58rem, 2.4vw, 1.78rem);
		line-height: 1.7;
		font-weight: 400;
	}

	@media (max-width: 900px) {
		.proposito .br-desktop {
			display: none;
		}
	}

	/* PROBLEMA */
	.problema {
		background: var(--bg-base);
		padding-top: 0;
		padding-bottom: 0;
	}

	.problema__split {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 6px;
		min-height: 70vh;
		background: linear-gradient(
			to bottom,
			rgba(0, 194, 255, 0.5),
			rgba(212, 0, 255, 0.5)
		);
	}

	.problema__imagen {
		position: relative;
		overflow: hidden;
	}

	.problema__imagen img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center 30%;
		display: block;
		transition: transform 0.8s var(--ease);
	}

	.problema__split:hover .problema__imagen img {
		transform: scale(1.03);
	}

	.problema__content {
		position: relative;
		z-index: 2;
		background: var(--bg-base);
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.problema__content .container {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding-block: clamp(2.5rem, 5vw, 4rem);
	}

	.problema__titulo {
		line-height: 0.95;
	}

	.problema__intro {
		color: var(--text-dim);
		font-size: clamp(1.58rem, 2.4vw, 1.78rem);
		font-weight: 500;
		letter-spacing: 0.02em;
	}

	.problema__lista {
		display: flex;
		flex-direction: column;
		gap: 0;
		list-style: none;
		padding: 0;
	}

	.problema__lista li {
		display: grid;
		grid-template-columns: 2.4rem 1fr;
		align-items: baseline;
		column-gap: 0.6rem;
		font-size: clamp(1.58rem, 2.4vw, 1.78rem);
		color: var(--text-secondary);
		line-height: 1.5;
		font-weight: 500;
		padding-block: 0.7rem;
		border-bottom: 1px solid var(--border);
		transition: color var(--t-fast) var(--ease);
	}

	.problema__lista li:first-child {
		border-top: 1px solid var(--border);
	}

	.problema__lista-num {
		font-family: var(--font-display);
		font-size: inherit;
		letter-spacing: 0.02em;
		background: linear-gradient(
			135deg,
			#00cfdd 0%,
			#0a2fa8 35%,
			#ff0035 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.problema__lista li:hover {
		color: var(--text-primary);
	}

	.problema__cierre {
		background: var(--bg-base);
		padding-block: 6.80625rem;
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	.problema__cierre::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(
			ellipse at 50% 100%,
			var(--cyan-subtle) 0%,
			transparent 65%
		);
		pointer-events: none;
	}

	.problema__mensaje {
		position: relative;
		z-index: 1;
	}

	@media (max-width: 900px) {
		.problema__split {
			grid-template-columns: 1fr;
			gap: 0;
			min-height: unset;
			background: none;
		}

		.problema__imagen {
			min-height: unset;
			aspect-ratio: 16/9;
			height: auto;
		}

		.problema__content .container {
			padding-bottom: 0;
		}

		.problema__lista li {
			grid-template-columns: 2rem 1fr;
		}
	}

	/* SOLUCIONES */
	.soluciones-seg {
		background: var(--bg-surface);
		padding-top: clamp(5rem, 10vw, 9rem);
		padding-bottom: clamp(4rem, 8vw, 6rem);
		scroll-margin-top: 100px;
	}

	.soluciones-seg__header {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
		margin-bottom: clamp(3rem, 6vw, 4.5rem);
	}

	.soluciones-seg__titulo {
		line-height: 0.95;
	}

	.soluciones-seg__header .divider {
		margin-bottom: 0;
	}

	.soluciones-seg__sub {
		color: var(--text-dim);
		font-size: clamp(1.58rem, 2.4vw, 1.78rem);
		font-weight: 500;
		letter-spacing: 0.02em;
		max-width: 40ch;
	}

	.soluciones-seg__imagen {
		position: relative;
		width: 100%;
		aspect-ratio: 16/6;
		overflow: hidden;
		margin-bottom: clamp(3rem, 6vw, 4.5rem);
	}

	.soluciones-seg__imagen img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.soluciones-seg__imagen::before {
		content: "";
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			var(--bg-surface) 0%,
			transparent 18%,
			transparent 82%,
			var(--bg-surface) 100%
		);
		pointer-events: none;
	}

	.soluciones-seg__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
		align-items: stretch;
	}

	.soluciones-seg__card-outer {
		position: relative;
		isolation: isolate;
		display: flex;
		flex-direction: column;
	}

	.soluciones-seg__card-outer::before {
		content: "";
		position: absolute;
		inset: -6px;
		border-radius: calc(var(--radius-lg) + 6px);
		background: linear-gradient(135deg, var(--cyan), var(--magenta));
		z-index: -1;
		opacity: 0.25;
		filter: blur(1px);
		transition: opacity var(--t-med) var(--ease);
	}

	.soluciones-seg__card-outer:hover::before {
		opacity: 0.55;
	}

	.soluciones-seg__card {
		background: var(--bg-card);
		border-radius: var(--radius-lg);
		padding: clamp(2rem, 3vw, 2.5rem);
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
		flex: 1;
	}

	.sb-b-item__header {
		display: grid;
		grid-template-columns: 44px 1fr;
		align-items: center;
		column-gap: 0.85rem;
		margin-bottom: 0.5rem;
	}

	.sb-b-item__icono {
		width: 44px;
		height: 44px;
		max-width: 44px;
		object-fit: contain;
	}

	.servicio-item__nombre {
		display: block;
		font-weight: 700;
		color: var(--text-primary);
		font-size: clamp(1.1rem, 1.6vw, 1.2rem);
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.servicio-item__desc {
		color: var(--text-secondary);
		font-size: clamp(1.58rem, 2.4vw, 1.78rem);
		line-height: 1.5;
		font-weight: 400;
	}

	.soluciones-seg__cta {
		display: flex;
		justify-content: center;
		margin-top: clamp(3rem, 6vw, 4rem);
	}

	.soluciones-seg__btn {
		background-image: linear-gradient(90deg, var(--cyan), var(--magenta));
		background-clip: text;
		-webkit-background-clip: text;
		color: transparent;
		border: 2px solid var(--cyan);
	}

	.soluciones-seg__btn:hover {
		filter: brightness(1.2);
		transform: translateY(-2px);
	}

	.soluciones-seg__frase {
		margin-top: 6.80625rem;
		display: flex;
		justify-content: center;
		text-align: center;
	}

	.soluciones-seg__frase-titulo {
		max-width: 18ch;
	}

	@media (max-width: 900px) {
		.soluciones-seg__grid {
			grid-template-columns: 1fr;
		}

		.soluciones-seg__imagen {
			aspect-ratio: 16/9;
		}
	}
</style>
