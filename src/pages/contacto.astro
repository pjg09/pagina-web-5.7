---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
	WHATSAPP_1,
	WHATSAPP_2,
	WHATSAPP_DEFAULT_MSG,
	EMAIL,
	INSTAGRAM,
	FACEBOOK,
	TIKTOK,
	URL_APP_WEB_CONTACTO,
} from "../data/constantes";
---

<BaseLayout
	title="Contacto"
	description="Síguenos en redes, escríbenos por correo o contacta directamente a nuestro equipo por WhatsApp."
>
	<!-- SECCIÓN 1 — FORMULARIO DE CONTACTO -->
	<section class="contacto-form-sec" aria-label="Formulario de contacto">
		<div class="container">
			<div class="contacto-form-header reveal">
				<h1 class="display display--lg contacto-form-header__titulo">
					HABLEMOS DE TU <span class="gradient-text">PROYECTO</span>
				</h1>
				<p class="contacto-form-header__sub">
					Cuéntanos qué estás construyendo, qué necesitas o qué
					objetivo quieres alcanzar. Nuestro equipo revisará tu
					información y te orientará sobre la mejor forma de avanzar.
				</p>
			</div>

			<div class="contacto-form-outer reveal reveal-delay-1">
				<form class="contacto-form" id="contacto-form" novalidate>
					<div class="contacto-form__grid">
						<div class="contacto-form__campo">
							<label for="cf-nombre" class="contacto-form__label"
								>Nombre</label
							>
							<input
								type="text"
								id="cf-nombre"
								name="nombre"
								class="contacto-form__input"
								placeholder="Tu nombre completo"
								required
							/>
						</div>

						<div class="contacto-form__campo">
							<label for="cf-email" class="contacto-form__label"
								>Correo electrónico</label
							>
							<input
								type="email"
								id="cf-email"
								name="email"
								class="contacto-form__input"
								placeholder="tucorreo@ejemplo.com"
								required
							/>
						</div>

						<div class="contacto-form__campo">
							<label
								for="cf-telefono"
								class="contacto-form__label">Teléfono</label
							>
							<input
								type="tel"
								id="cf-telefono"
								name="telefono"
								class="contacto-form__input"
								placeholder="+57 300 000 0000"
								required
							/>
						</div>

						<div class="contacto-form__campo">
							<label for="cf-empresa" class="contacto-form__label"
								>Empresa / Razón Social / Nombre Artístico</label
							>
							<input
								type="text"
								id="cf-empresa"
								name="empresa"
								class="contacto-form__input"
								placeholder="¿Cómo se llama tu marca o proyecto?"
								required
							/>
						</div>

						<div class="contacto-form__campo">
							<span class="contacto-form__label"
								>Línea de interés</span
							>
							<div
								class="contacto-form__toggle"
								role="radiogroup"
								aria-label="Línea de producto"
							>
								<label class="contacto-form__toggle-option">
									<input
										type="radio"
										name="linea"
										value="marca"
										required
									/>
									<span>Marca</span>
								</label>
								<label class="contacto-form__toggle-option">
									<input
										type="radio"
										name="linea"
										value="artista"
										required
									/>
									<span>Artista</span>
								</label>
							</div>
						</div>

						<div class="contacto-form__campo">
							<label
								for="cf-instagram"
								class="contacto-form__label"
								>Usuario de Instagram</label
							>
							<input
								type="text"
								id="cf-instagram"
								name="instagram"
								class="contacto-form__input"
								placeholder="@tuusuario"
								required
							/>
						</div>
					</div>

					<div class="contacto-form__campo">
						<label for="cf-necesidad" class="contacto-form__label"
							>Descripción de tu necesidad</label
						>
						<textarea
							id="cf-necesidad"
							name="necesidad"
							class="contacto-form__input contacto-form__textarea"
							rows="5"
							placeholder="Cuéntanos qué estás buscando y cómo podemos ayudarte."
							required></textarea>
					</div>

					<button
						type="submit"
						id="contacto-form__submit"
						class="btn contacto-form__btn"
						disabled
					>
						Enviar solicitud
					</button>

					<p
						id="contacto-form__feedback"
						class="contacto-form__feedback"
						role="status"
						aria-live="polite"
					>
					</p>
				</form>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 2 — OTRAS FORMAS DE CONTACTO -->
	<section class="otras-sec" aria-label="Otras formas de contacto">
		<div class="container">
			<div class="otras-header reveal">
				<h2 class="display display--lg otras-header__titulo">
					OTRAS FORMAS DE <span class="gradient-text">CONTACTARNOS</span>
				</h2>
				<p class="otras-header__sub">
					Si prefieres una atención directa, también puedes comunicarte con nuestro equipo por cualquiera de estos medios.
				</p>
			</div>

			<div class="otras-cards">

				<!-- WhatsApp -->
				<div class="rep-outer reveal reveal-delay-1">
					<div class="rep">
						<div class="rep__icono-circle">
							<svg width="48" height="48" viewBox="0 0 24 24" fill="var(--cyan)" aria-hidden="true">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
								<path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.524 5.849L.057 23.625a.5.5 0 0 0 .614.633l5.9-1.545A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.792 9.792 0 0 1-5.007-1.373l-.36-.214-3.724.976.994-3.624-.235-.374A9.786 9.786 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
							</svg>
						</div>
						<div class="rep__info">
							<span class="rep__nombre">WHATSAPP</span>
							<span class="rep__desc">Atención directa para consultas, información comercial y acompañamiento.</span>
							<a
								href={`${WHATSAPP_1}?text=${WHATSAPP_DEFAULT_MSG}`}
								target="_blank"
								rel="noopener noreferrer"
								class="rep__btn"
							>
								<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
									<path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.524 5.849L.057 23.625a.5.5 0 0 0 .614.633l5.9-1.545A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.792 9.792 0 0 1-5.007-1.373l-.36-.214-3.724.976.994-3.624-.235-.374A9.786 9.786 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
								</svg>
								Hablar por WhatsApp
							</a>
						</div>
					</div>
				</div>

				<!-- Correo -->
				<div class="rep-outer reveal reveal-delay-2">
					<div class="rep">
						<div class="rep__icono-circle">
							<svg width="48" height="48" viewBox="0 0 24 24" fill="var(--cyan)" aria-hidden="true">
								<path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
							</svg>
						</div>
						<div class="rep__info">
							<span class="rep__nombre">CORREO ELECTRÓNICO</span>
							<span class="rep__desc">Envíanos tu consulta y te responderemos a la mayor brevedad posible.</span>
							<span class="rep__tel">{EMAIL}</span>
							<a href={`mailto:${EMAIL}`} class="rep__btn">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
								</svg>
								Enviar correo
							</a>
						</div>
					</div>
				</div>

			</div>
		</div>
	</section>
	<div class="section-line"></div>

	<!-- SECCIÓN 3 — ATENCIÓN DIRECTA -->
	<section class="atencion-sec" aria-label="Atención directa">
		<div class="container">

			<div class="atencion-header reveal">
				<h2 class="display display--lg atencion-header__titulo">
					ATENCIÓN <span class="gradient-text">DIRECTA</span>
				</h2>
				<p class="atencion-header__sub">
					Si ya conoces nuestros servicios y deseas hablar directamente con uno de nuestros representantes, puedes comunicarte por WhatsApp.
				</p>
			</div>

			<div class="atencion-grid">

				<!-- Jessmar -->
				<div class="rep-outer reveal reveal-delay-1">
					<div class="rep">
						<div class="rep__foto">
							<img src="/images/FotoJess.jpg" alt="Jessmar" />
						</div>
						<div class="rep__info">
							<span class="rep__nombre">Jessmar</span>
							<span class="rep__cargo rep__cargo--magenta">Directora General</span>
							<span class="rep__tel">+57 321 286 5200</span>
							<a
								href={`${WHATSAPP_1}?text=${WHATSAPP_DEFAULT_MSG}`}
								target="_blank"
								rel="noopener noreferrer"
								class="rep__btn"
							>
								<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
									<path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.524 5.849L.057 23.625a.5.5 0 0 0 .614.633l5.9-1.545A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.792 9.792 0 0 1-5.007-1.373l-.36-.214-3.724.976.994-3.624-.235-.374A9.786 9.786 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
								</svg>
								Contactar Directora
							</a>
						</div>
					</div>
				</div>

				<!-- Adrián -->
				<div class="rep-outer reveal reveal-delay-2">
					<div class="rep">
						<div class="rep__foto">
							<img src="/images/FotoAdrian.jpg" alt="Adrián" />
						</div>
						<div class="rep__info">
							<span class="rep__nombre">Adrián</span>
							<span class="rep__cargo rep__cargo--cyan">Subdirector General</span>
							<span class="rep__tel">+57 312 544 8302</span>
							<a
								href={`${WHATSAPP_2}?text=${WHATSAPP_DEFAULT_MSG}`}
								target="_blank"
								rel="noopener noreferrer"
								class="rep__btn"
							>
								<svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
									<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
									<path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.524 5.849L.057 23.625a.5.5 0 0 0 .614.633l5.9-1.545A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.792 9.792 0 0 1-5.007-1.373l-.36-.214-3.724.976.994-3.624-.235-.374A9.786 9.786 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
								</svg>
								Contactar Subdirector
							</a>
						</div>
					</div>
				</div>

			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 4 — REDES SOCIALES -->
	<section class="redes-sec" aria-label="Redes sociales">
		<div class="container">

			<div class="redes-header reveal">
				<h2 class="display display--lg redes-header__titulo">
					SÍGUENOS Y CONOCE MÁS<br class="br-desktop" /> DE <span class="gradient-text">OCL 5.7</span>
				</h2>
				<p class="redes-header__sub">
					Descubre nuestros proyectos, servicios y novedades a través de nuestros canales digitales.
				</p>
			</div>

			<div class="redes-grid">

				<!-- Instagram -->
				<a href={INSTAGRAM} target="_blank" rel="noopener noreferrer" class="red-outer reveal reveal-delay-1">
					<div class="red">
						<div class="red__icono-wrap red__icono-wrap--ig">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
								<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
							</svg>
						</div>
						<div class="red__info">
							<span class="red__plataforma">Instagram</span>
							<span class="red__handle">@ondacreativalaunch5.7</span>
							<span class="red__cta">Seguir →</span>
						</div>
					</div>
				</a>

				<!-- Facebook -->
				<a href={FACEBOOK} target="_blank" rel="noopener noreferrer" class="red-outer reveal reveal-delay-2">
					<div class="red">
						<div class="red__icono-wrap red__icono-wrap--fb">
							<svg width="32" height="32" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
								<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
							</svg>
						</div>
						<div class="red__info">
							<span class="red__plataforma">Facebook</span>
							<span class="red__handle">ondacreativalaunch5.7</span>
							<span class="red__cta">Seguir →</span>
						</div>
					</div>
				</a>

				<!-- TikTok -->
				<a href={TIKTOK} target="_blank" rel="noopener noreferrer" class="red-outer reveal reveal-delay-3">
					<div class="red">
						<div class="red__icono-wrap red__icono-wrap--tt">
							<svg width="30" height="30" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
								<path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.22 8.22 0 0 0 4.81 1.53V6.75a4.85 4.85 0 0 1-1.04-.06z"/>
							</svg>
						</div>
						<div class="red__info">
							<span class="red__plataforma">TikTok</span>
							<span class="red__handle">@ondacreativalaunch5.7</span>
							<span class="red__cta">Seguir →</span>
						</div>
					</div>
				</a>

			</div>
		</div>
	</section>

	<script define:vars={{ URL_APP_WEB_CONTACTO }}>
		const contactForm = document.getElementById("contacto-form");
		const submitBtn = document.getElementById("contacto-form__submit");
		const feedbackEl = document.getElementById("contacto-form__feedback");

		function validateContactForm() {
			const requiredFields = contactForm.querySelectorAll("[required]");
			let allFilled = true;

			requiredFields.forEach((field) => {
				if (field.type === "radio") {
					const checked = contactForm.querySelector(
						`input[name="${field.name}"]:checked`,
					);
					if (!checked) allFilled = false;
				} else if (!field.value.trim()) {
					allFilled = false;
				}
			});

			const email = contactForm.querySelector("#cf-email").value.trim();
			const emailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

			submitBtn.disabled = !(allFilled && emailValid);
		}

		contactForm.addEventListener("input", validateContactForm);
		contactForm.addEventListener("change", validateContactForm);
		validateContactForm();

		contactForm.addEventListener("submit", async (event) => {
			event.preventDefault();

			const formData = new FormData(contactForm);
			const payload = Object.fromEntries(formData.entries());

			submitBtn.disabled = true;
			submitBtn.textContent = "Enviando...";
			feedbackEl.textContent = "";
			feedbackEl.classList.remove(
				"contacto-form__feedback--ok",
				"contacto-form__feedback--error",
			);

			try {
				// mode: no-cors evita el error CORS al leer la respuesta de Apps Script.
				// La respuesta queda opaca — no podemos leerla, pero el POST sí llega.
				await fetch(URL_APP_WEB_CONTACTO, {
					method: "POST",
					mode: "no-cors",
					body: JSON.stringify(payload),
				});

				contactForm.reset();
				feedbackEl.textContent =
					"¡Listo! Recibimos tu solicitud, revisa tu correo para la confirmación.";
				feedbackEl.classList.add("contacto-form__feedback--ok");
			} catch (error) {
				feedbackEl.textContent =
					"No pudimos enviar tu solicitud. Intenta de nuevo o escríbenos por WhatsApp.";
				feedbackEl.classList.add("contacto-form__feedback--error");
			} finally {
				submitBtn.textContent = "Enviar solicitud";
				validateContactForm();
			}
		});
	</script>
</BaseLayout>

