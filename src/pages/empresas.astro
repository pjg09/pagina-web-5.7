---
import BaseLayout from "../layouts/BaseLayout.astro";
import { WHATSAPP_CTA, CALENDLY_EMPRESAS } from "../data/constantes";
---

<BaseLayout
    title="Empresas"
    description="Construimos una presencia digital clara, profesional y enfocada en resultados para empresas y marcas."
>
    <!-- SECCIÓN 1 — HERO -->
    <section class="hero" aria-label="Hero empresas">
        <div class="hero__bg">
            <img
                src="/images/HeroEmpresas.jpg"
                alt="Empresas y marcas con dirección"
                class="hero__img"
                fetchpriority="high"
            />
            <div class="hero__overlay"></div>
        </div>

        <div class="container hero__content">
            <h1 class="display display--xl hero__title reveal reveal-delay-1">
                HACEMOS QUE TU MARCA<br />
                SE VEA <span class="gradient-text">PROFESIONAL</span>,<br />
                CONECTE Y <span class="gradient-text">VENDA</span>
            </h1>

            <p class="body--lg hero__sub reveal reveal-delay-2">
                Construimos una presencia digital clara, profesional y enfocada
                en resultados.
            </p>

            <div class="hero__ctas reveal reveal-delay-3">
                <a href="#soluciones" class="btn hero__btn">
                    Ver cómo potenciar mi marca
                </a>
                <a
                    href={CALENDLY_EMPRESAS}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn hero__btn hero__btn--secondary"
                >
                    Agendar diagnóstico sin costo
                </a>
            </div>

            <a
                href="#soluciones"
                class="hero__scroll reveal reveal-delay-4"
                aria-label="Ver soluciones para empresas"
            >
                <span>Conocer más</span>
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                >
                    <path
                        d="M8 3v10M3 8l5 5 5-5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                </svg>
            </a>
        </div>
    </section>

    <div class="section-line"></div>

    <!-- SECCIÓN 2 — PROPÓSITO / LA BASE -->
    <section class="base" id="soluciones" aria-label="La base para tu marca">
        <div class="container">
            <div class="base__grid">
                <div class="base__visual reveal">
                    <div class="base__img-wrapper">
                        <img
                            src="/images/InternaEmpresas01.jpeg"
                            alt="Equipo trabajando en estrategia de marca"
                            loading="lazy"
                            class="base__img"
                        />
                        <div class="base__img-overlay"></div>
                    </div>
                </div>

                <div class="base__text reveal reveal-delay-2">
                    <div class="divider"></div>
                    <h2 class="display display--md base__title">
                        LA BASE PARA QUE TU MARCA <span class="gradient-text"
                            >SE VEA, CONECTE Y VENDA</span
                        >
                    </h2>
                    <p class="body--lg base__body">
                        Hoy no se trata solo de estar en internet. Se trata de
                        tener una estructura clara que te permita verte
                        profesional, generar confianza y convertir atención en
                        clientes.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <div class="section-line"></div>

    <!-- SECCIÓN 3 — EL PROBLEMA -->
    <section
        class="problema"
        aria-label="Lo que frena el crecimiento de tu marca"
    >
        <!-- 3A — Texto centrado, sin imagen -->
        <div class="container">
            <div class="problema__content">
                <div class="reveal">
                    <h2 class="display display--lg problema__titulo">
                        LO QUE ESTÁ FRENANDO<br />
                        EL CRECIMIENTO DE<br />
                        TU <span class="gradient-text">MARCA</span>
                    </h2>
                </div>
                <ul class="problema__lista reveal reveal-delay-1">
                    <li>Presencia digital débil o desordenada</li>
                    <li>Redes sociales sin dirección estratégica</li>
                    <li>Contenido visual poco profesional</li>
                    <li>Baja conexión con la audiencia</li>
                    <li>Dificultad para convertir visibilidad en ventas</li>
                </ul>
            </div>
        </div>

        <!-- 3B — Mensaje cierre -->
        <div class="problema__cierre">
            <div class="container">
                <p class="problema__mensaje reveal">
                    <span class="gradient-text"
                        >LA VISIBILIDAD SIN ESTRUCTURA NO CONVIERTE</span
                    >
                </p>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 4 — SOLUCIONES -->
    <section class="soluciones" aria-label="Soluciones para tu marca">
        <!-- 4A — HEADER SIN IMAGEN -->
        <div class="sol-intro">
            <div class="container sol-intro__inner">
                <h2 class="display display--lg reveal reveal-delay-1">
                    SOLUCIONES QUE <br />HACEN QUE TU <br /><span
                        class="gradient-text">MARCA</span
                    > AVANCE
                </h2>
                <p class="sol-intro__texto reveal reveal-delay-2">
                    Esto es lo que construimos para que tu marca crezca con
                    dirección:
                </p>
            </div>
        </div>

        <!-- 4B — INFRAESTRUCTURA DIGITAL + imagen derecha -->
        <div class="sol-cat sol-cat--surface">
            <div class="container">
                <div class="sol-cat__header reveal">
                    <span class="sol-cat__num">01</span>
                    <h3 class="display display--md sol-cat__titulo">
                        INFRAESTRUCTURA DIGITAL
                    </h3>
                    <p class="sol-cat__desc">
                        Desarrollamos la base digital de tu marca para que
                        puedas ser encontrado, comunicarte mejor y proyectarte
                        de forma profesional.
                    </p>
                </div>
                <div class="sol-cat__layout">
                    <div class="sol-cat__services">
                        <div class="sol-grid sol-grid--2">
                            <div class="sol-item reveal">
                                <img
                                    src="/images/PaginaWeb.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Diseño y creación<br />de páginas web
                                </h4>
                                <p class="sol-item__desc">
                                    Desarrollamos tu página web profesional para
                                    que tu marca tenga presencia sólida, clara y
                                    confiable en internet.
                                </p>
                            </div>
                            <div class="sol-item reveal reveal-delay-1">
                                <img
                                    src="/images/LandingPage.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Diseño y creación<br />de landing pages
                                </h4>
                                <p class="sol-item__desc">
                                    Creamos páginas enfocadas en convertir
                                    visitas en contactos o ventas de forma
                                    directa.
                                </p>
                            </div>
                            <div class="sol-item reveal reveal-delay-2">
                                <img
                                    src="/images/BioLink.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Bio link<br />profesional
                                </h4>
                                <p class="sol-item__desc">
                                    Organizamos todos tus enlaces en un solo
                                    lugar con una imagen limpia y estratégica.
                                </p>
                            </div>
                            <div class="sol-item reveal">
                                <img
                                    src="/images/GoogleProfile.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Google Business<br />Profile
                                </h4>
                                <p class="sol-item__desc">
                                    Creamos u optimizamos tu negocio para que
                                    aparezcas en búsquedas y mapas, facilitando
                                    que te encuentren.
                                </p>
                            </div>
                            <div class="sol-item reveal reveal-delay-1">
                                <img
                                    src="/images/WhatsappBusiness.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    WhatsApp<br />Business
                                </h4>
                                <p class="sol-item__desc">
                                    Configuramos tu canal de contacto para
                                    atención rápida, organizada y profesional.
                                </p>
                            </div>
                            <div class="sol-item reveal reveal-delay-2">
                                <img
                                    src="/images/PortafolioDigital.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Diseño de portafolios<br />comerciales
                                    digitales
                                </h4>
                                <p class="sol-item__desc">
                                    Creamos presentaciones claras y bien
                                    estructuradas para mostrar tus servicios o
                                    productos.
                                </p>
                            </div>
                            <div class="sol-item reveal">
                                <img
                                    src="/images/AuditoriaDigital.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Auditoría de<br />Presencia Digital
                                </h4>
                                <p class="sol-item__desc">
                                    Analizamos tu estado actual y detectamos
                                    oportunidades claras de mejora.
                                </p>
                            </div>
                        </div>
                        <div class="sol-cat__cta reveal">
                            <a
                                href={CALENDLY_EMPRESAS}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn sol-btn"
                                >Quiero estructurar mi marca</a
                            >
                        </div>
                    </div>
                    <div class="sol-cat__imagen reveal reveal-delay-2">
                        <img
                            src="/images/InternaEmpresas02.jpeg"
                            alt="Infraestructura digital para marcas"
                            loading="lazy"
                        />
                    </div>
                </div>
            </div>
        </div>

        <!-- 4C — REDES SOCIALES + imagen izquierda -->
        <div class="sol-cat sol-cat--base">
            <div class="container">
                <div class="sol-cat__header reveal">
                    <span class="sol-cat__num">02</span>
                    <h3 class="display display--md sol-cat__titulo">
                        REDES SOCIALES
                    </h3>
                    <p class="sol-cat__desc">
                        Hacemos que tu marca se vea activa, coherente y con
                        dirección, conectando con tu audiencia.
                    </p>
                </div>
                <div class="sol-cat__layout sol-cat__layout--reverse">
                    <div class="sol-cat__imagen reveal">
                        <img
                            src="/images/InternaEmpresas03.jpeg"
                            alt="Redes sociales con estrategia"
                            loading="lazy"
                        />
                    </div>
                    <div class="sol-cat__services">
                        <div class="sol-grid sol-grid--1">
                            <div class="sol-item sol-item--card reveal">
                                <img
                                    src="/images/AdministrarRedes.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Administración<br />de redes
                                </h4>
                                <p class="sol-item__desc">
                                    Gestionamos tu contenido para que tu marca
                                    se vea activa, organizada y profesional.
                                </p>
                            </div>
                            <div
                                class="sol-item sol-item--card reveal reveal-delay-1"
                            >
                                <img
                                    src="/images/PautaPublicitaria.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Pauta<br />publicitaria
                                </h4>
                                <p class="sol-item__desc">
                                    Creamos campañas para llegar a más personas
                                    y atraer clientes potenciales.
                                </p>
                            </div>
                        </div>
                        <div class="sol-cat__cta reveal">
                            <a
                                href={CALENDLY_EMPRESAS}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn sol-btn">Quiero activar mis redes</a
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4D — PRODUCCIÓN AUDIOVISUAL + imagen derecha -->
        <div class="sol-cat sol-cat--surface">
            <div class="container">
                <div class="sol-cat__header reveal">
                    <span class="sol-cat__num">03</span>
                    <h3 class="display display--md sol-cat__titulo">
                        PRODUCCIÓN AUDIOVISUAL
                    </h3>
                    <p class="sol-cat__desc">
                        Creamos contenido visual que eleva la percepción de tu
                        marca y transmite confianza.
                    </p>
                </div>
                <div class="sol-cat__layout">
                    <div class="sol-cat__services">
                        <div class="sol-grid sol-grid--1">
                            <div class="sol-item reveal">
                                <img
                                    src="/images/Fotografia.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Fotografía<br />profesional
                                </h4>
                                <p class="sol-item__desc">
                                    Imágenes que transmiten calidad y elevan la
                                    percepción de tu marca.
                                </p>
                            </div>
                            <div class="sol-item reveal reveal-delay-1">
                                <img
                                    src="/images/VideosCorporativos.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Videos<br />corporativos
                                </h4>
                                <p class="sol-item__desc">
                                    Contenido que presenta tu marca de forma
                                    clara, profesional y confiable.
                                </p>
                            </div>
                            <div class="sol-item reveal reveal-delay-2">
                                <img
                                    src="/images/VideosRedes.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Videos<br />para redes
                                </h4>
                                <p class="sol-item__desc">
                                    Piezas diseñadas para captar atención y
                                    generar interacción en plataformas
                                    digitales.
                                </p>
                            </div>
                        </div>
                        <div class="sol-cat__cta reveal">
                            <a
                                href={CALENDLY_EMPRESAS}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn sol-btn">Quiero mejorar mi imagen</a
                            >
                        </div>
                    </div>
                    <div class="sol-cat__imagen reveal reveal-delay-2">
                        <img
                            src="/images/InternaEmpresas04.jpeg"
                            alt="Producción audiovisual profesional"
                            loading="lazy"
                        />
                    </div>
                </div>
            </div>
        </div>

        <!-- 4E — INFLUENCERS + imagen izquierda -->
        <div class="sol-cat sol-cat--base">
            <div class="container">
                <div class="sol-cat__header reveal">
                    <span class="sol-cat__num">04</span>
                    <h3 class="display display--md sol-cat__titulo">
                        INFLUENCERS
                    </h3>
                    <p class="sol-cat__desc">
                        Aumentamos tu alcance conectando tu marca con creadores
                        que generan visibilidad y credibilidad.
                    </p>
                </div>
                <div class="sol-cat__layout sol-cat__layout--reverse">
                    <div class="sol-cat__imagen reveal">
                        <img
                            src="/images/InternaEmpresas05.jpeg"
                            alt="Influencers y colaboraciones"
                            loading="lazy"
                        />
                    </div>
                    <div class="sol-cat__services">
                        <div class="sol-grid sol-grid--1">
                            <div class="sol-item sol-item--card reveal">
                                <img
                                    src="/images/GestionInfluencers.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Gestión de influencers<br />para campañas
                                    publicitarias
                                </h4>
                                <p class="sol-item__desc">
                                    Conectamos tu marca con creadores que
                                    amplifican tu alcance.
                                </p>
                            </div>
                            <div
                                class="sol-item sol-item--card reveal reveal-delay-1"
                            >
                                <img
                                    src="/images/Colaboraciones.png"
                                    alt=""
                                    class="sol-item__icono"
                                    aria-hidden="true"
                                />
                                <h4 class="sol-item__titulo">
                                    Colaboraciones<br />estratégicas
                                </h4>
                                <p class="sol-item__desc">
                                    Diseñamos acciones con influencers para
                                    generar visibilidad y confianza.
                                </p>
                            </div>
                        </div>
                        <div class="sol-cat__cta reveal">
                            <a
                                href={CALENDLY_EMPRESAS}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn sol-btn">Quiero más alcance</a
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="section-line"></div>

    <!-- SECCIÓN 5 — DIAGNÓSTICO ESTRATÉGICO -->
    <section
        class="diagnostico"
        aria-label="Diagnóstico estratégico para tu empresa"
    >
        <div class="container diagnostico__inner">
            <!-- Lado izquierdo: título + textos + logística -->
            <div class="diagnostico__texto reveal">
                <h2 class="display display--lg diagnostico__titulo">
                    DIAGNÓSTICO ESTRATÉGICO<br />
                    PARA TU <span class="gradient-text">EMPRESA</span>
                </h2>
                <p class="diagnostico__intro">
                    Si sabes que tu marca puede crecer más, pero no tienes claro
                    cómo estructurarla correctamente, esta reunión es el
                    siguiente paso.
                </p>

                <div class="diagnostico__logistica">
                    <div class="diagnostico__dato">
                        <span class="diagnostico__dato-label">Duración</span>
                        <span class="diagnostico__dato-valor"
                            >40–50 minutos</span
                        >
                    </div>
                    <div class="diagnostico__dato">
                        <span class="diagnostico__dato-label">Modalidad</span>
                        <span class="diagnostico__dato-valor"
                            >Virtual o presencial</span
                        >
                    </div>
                </div>
            </div>

            <!-- Lado derecho: evaluación + conclusión + botón -->
            <div class="diagnostico__contenido reveal reveal-delay-1">
                <div class="diagnostico__bloque">
                    <p class="diagnostico__bloque-intro">
                        Durante esta conversación evaluaremos:
                    </p>
                    <ul class="diagnostico__lista">
                        <li>Presencia digital actual</li>
                        <li>Canales de contacto</li>
                        <li>Comunicación visual de la marca</li>
                        <li>Oportunidades de mejora</li>
                    </ul>
                </div>

                <p class="diagnostico__conclusion">
                    Al finalizar la reunión podremos definir si existe una
                    oportunidad real de trabajo conjunto y qué soluciones serían
                    más adecuadas para tu empresa.
                </p>

                <a
                    href={CALENDLY_EMPRESAS}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn diagnostico__btn"
                >
                    Agendar reunión
                </a>
            </div>
        </div>
    </section>

    <div class="section-line"></div>

    <!-- SECCIÓN 6 — CIERRE -->
    <section class="cierre-empresas" aria-label="Llamada a la acción final">
        <div class="container cierre-empresas__inner">
            <p class="display display--lg cierre-empresas__mensaje reveal">
                <span class="gradient-text"
                    >Tu marca necesita<br />estructura digital real</span
                >
            </p>
            <div class="reveal reveal-delay-2">
                <a
                    href={WHATSAPP_CTA}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn cierre-empresas__btn"
                >
                    Hablemos por WhatsApp
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* HERO */
    .hero {
        position: relative;
        min-height: 100svh;
        display: flex;
        align-items: flex-end;
        padding-top: 140px;
        padding-bottom: clamp(4rem, 8vw, 7rem);
        overflow: hidden;
    }

    .hero__bg {
        position: absolute;
        inset: 0;
    }

    .hero__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
    }

    .hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to right,
            rgba(8, 8, 16, 0.92) 0%,
            rgba(8, 8, 16, 0.65) 50%,
            rgba(8, 8, 16, 0.1) 100%
        );
    }

    .hero__content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.5rem;
        max-width: 55%;
        margin-left: 0;
        margin-right: auto;
    }

    @media (max-width: 768px) {
        .hero__content {
            max-width: 100%;
        }
    }

    .hero__title {
        line-height: 1.05;
    }

    .hero__sub {
        color: var(--text-high);
        font-size: 1.35rem;
        max-width: 44ch;
        font-weight: 500;
    }

    @media (max-width: 768px) {
        .hero__sub {
            font-size: 1.1rem;
        }
    }

    .hero__ctas {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .hero__btn {
        background: #fff;
        color: #000;
        border: none;
    }

    .hero__btn:hover {
        background: #fff;
        border: 2px solid var(--empresa);
        transform: translateY(-2px);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        background-image: linear-gradient(90deg, var(--empresa), #ff6b9d);
    }

    .hero__btn--secondary {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.4);
    }

    .hero__btn--secondary:hover {
        background: transparent;
        border: 2px solid var(--empresa);
        color: var(--empresa);
        background-image: none;
        background-clip: unset;
        -webkit-background-clip: unset;
    }

    .hero__scroll {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text-dim);
        margin-top: 1rem;
        transition: color var(--t-fast) var(--ease);
    }

    .hero__scroll:hover {
        color: var(--empresa);
    }

    /* SECCIÓN 2 — LA BASE */
    .base {
        padding-block: var(--section-gap);
        background: var(--bg-surface);
    }

    .base__grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(3rem, 6vw, 6rem);
        align-items: center;
    }

    .base__img-wrapper {
        position: relative;
        border-radius: var(--radius-lg);
        overflow: hidden;
        border: 1px solid var(--empresa-dim);
    }

    .base__img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        aspect-ratio: 4 / 5;
        transition: transform 0.8s var(--ease);
    }

    .base__visual:hover .base__img {
        transform: scale(1.03);
    }

    .base__img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(8, 8, 16, 0.45) 0%,
            transparent 60%
