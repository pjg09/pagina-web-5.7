---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAWhatsApp from "../components/CTAWhatsApp.astro";
import { WHATSAPP_CTA } from "../data/constantes";
---

<BaseLayout
	title="Inicio"
	description="Desarrollamos identidad, narrativa y presencia para marcas y artistas que quieren crecer con estructura."
>
	<!--SECCIÓN 1 — HERO -->
	<section class="hero" aria-label="Hero principal">
		<div class="hero__bg">
			<img
				src="/images/HERO_PRINCIPAL_1.jpeg"
				alt="5.7 Onda Creativa Launch"
				class="hero__img"
				fetchpriority="high"
			/>
			<div class="hero__overlay"></div>
		</div>

		<div class="container hero__content">
			<h1 class="display display--xl hero__title reveal reveal-delay-1">
				Construimos<br />
				<span class="gradient-text">marcas</span><br />
				con dirección
			</h1>

			<p class="body--lg hero__sub reveal reveal-delay-2">
				Desarrollamos identidad, narrativa y presencia para marcas<br
					class="br-desktop"
				/>
				y artistas que quieren crecer con estructura.
			</p>
			<div class="hero__ctas reveal reveal-delay-3">
				<a href="/artistas" class="btn btn--primary">
					🎤 Soy artista
				</a>
				<a href="/empresas" class="btn btn--outline">
					🏢 Soy empresa
				</a>
			</div>

			<a
				href="#metodo"
				class="hero__scroll reveal reveal-delay-4"
				aria-label="Ver cómo trabajamos"
			>
				<span>Conocer cómo trabajamos</span>
				<svg
					width="16"
					height="16"
					viewBox="0 0 16 16"
					fill="none"
					aria-hidden="true"
				>
					<path
						d="M8 3v10M3 8l5 5 5-5"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</a>
		</div>
	</section>

	<!-- SECCIÓN 2 — IDENTIFICACIÓN RÁPIDA -->
	<section
		class="identificacion"
		id="metodo"
		aria-label="Para artistas y empresas"
	>
		<div class="container">
			<div class="identificacion__grid">
				<!-- Artistas -->
				<article class="id-card id-card--artistas reveal">
					<div class="id-card__image">
						<img
							src="/images/_02.jpeg"
							alt="Artista trabajando en estudio"
							loading="lazy"
						/>
						<div class="id-card__image-overlay"></div>
					</div>
					<div class="id-card__body">
						<span class="id-card__icon" aria-hidden="true">🎤</span>
						<h2 class="display display--sm id-card__title">
							Para artistas
						</h2>
						<p class="id-card__text">
							Tienes talento.<br />
							<strong
								>Pero sin estructura no hay posicionamiento.</strong
							>
						</p>
						<div class="divider"></div>
						<p class="body--sm">Ahí es donde entra 5.7.</p>
						<a
							href="/artistas"
							class="btn btn--primary id-card__btn"
							>Ver soluciones</a
						>
					</div>
				</article>

				<!-- Empresas -->
				<article
					class="id-card id-card--empresas reveal reveal-delay-2"
				>
					<div class="id-card__image">
						<img
							src="/images/_03.jpeg"
							alt="Equipo de trabajo en agencia"
							loading="lazy"
						/>
						<div
							class="id-card__image-overlay id-card__image-overlay--magenta"
						>
						</div>
					</div>
					<div class="id-card__body">
						<span class="id-card__icon" aria-hidden="true">🏢</span>
						<h2 class="display display--sm id-card__title">
							Para marcas
						</h2>
						<p class="id-card__text">
							Tienes negocio.<br />
							<strong
								>Pero sin estrategia no hay autoridad.</strong
							>
						</p>
						<div
							class="divider"
							style="background: linear-gradient(90deg, var(--magenta), var(--cyan));"
						>
						</div>
						<p class="body--sm">Ahí es donde entra 5.7.</p>
						<a
							href="/empresas"
							class="btn btn--outline id-card__btn"
							>Ver soluciones</a
						>
					</div>
				</article>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 3 — QUÉ HACEMOS -->
	<section class="que-hacemos" aria-label="Qué hacemos">
		<div class="container">
			<div class="que-hacemos__inner">
				<div class="que-hacemos__text">
					<span class="label reveal">Nuestro enfoque</span>
					<h2 class="display display--lg reveal reveal-delay-1">
						Qué<br /><span class="gradient-text">hacemos</span>
					</h2>
					<ul class="que-hacemos__list">
						<li class="que-hacemos__item reveal reveal-delay-1">
							<span class="que-hacemos__num">01</span>
							<p>Construimos estructura digital.</p>
						</li>
						<li class="que-hacemos__item reveal reveal-delay-2">
							<span class="que-hacemos__num">02</span>
							<p>Ejecutamos visibilidad estratégica.</p>
						</li>
						<li class="que-hacemos__item reveal reveal-delay-3">
							<span class="que-hacemos__num">03</span>
							<p>Producimos imagen profesional.</p>
						</li>
						<li class="que-hacemos__item reveal reveal-delay-4">
							<span class="que-hacemos__num">04</span>
							<p>Acompañamos crecimiento real.</p>
						</li>
					</ul>
					<a href="/artistas" class="btn btn--outline reveal"
						>Ver cómo trabajamos</a
					>
				</div>

				<div class="que-hacemos__visual reveal reveal-delay-2">
					<img
						src="/images/_04.jpeg"
						alt="Equipo de producción digital"
						loading="lazy"
						class="que-hacemos__img"
					/>
					<div class="que-hacemos__img-border"></div>
				</div>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 4 — EL PROBLEMA QUE RESOLVEMOS -->
	<section class="problema" aria-label="El problema que resolvemos">
		<div class="container">
			<div class="problema__header reveal">
				<span class="label">El problema que resolvemos</span>
				<h2 class="display display--lg">
					¿Te suena<br /><span class="gradient-text">familiar?</span>
				</h2>
			</div>

			<div class="problema__grid">
				<!-- Artistas -->
				<article class="problema-card reveal">
					<div class="problema-card__image">
						<img
							src="/images/_05.jpeg"
							alt="Artista sin visibilidad digital"
							loading="lazy"
						/>
						<div class="problema-card__badge">🎤 Artistas</div>
					</div>
					<div class="problema-card__body">
						<ul class="problema-card__list">
							<li>No logran visibilidad real</li>
							<li>Lanzan sin estrategia</li>
							<li>No saben cómo posicionar su música</li>
							<li>No tienen estructura profesional</li>
							<li>No generan credibilidad digital</li>
						</ul>
						<p class="problema-card__message">
							El talento sin estrategia no se posiciona.
						</p>
						<a href="/artistas" class="btn btn--primary"
							>Ver soluciones para artistas</a
						>
					</div>
				</article>

				<!-- Empresas -->
				<article class="problema-card reveal reveal-delay-2">
					<div class="problema-card__image">
						<img
							src="/images/_06.jpeg"
							alt="Empresa sin presencia digital estructurada"
							loading="lazy"
						/>
						<div
							class="problema-card__badge problema-card__badge--magenta"
						>
							🏢 Empresas
						</div>
					</div>
					<div class="problema-card__body">
						<ul class="problema-card__list">
							<li>Publican sin dirección estratégica</li>
							<li>No proyectan profesionalismo</li>
							<li>No generan autoridad digital</li>
							<li>No aprovechan el video</li>
							<li>No tienen presencia digital estructurada</li>
						</ul>
						<p
							class="problema-card__message problema-card__message--magenta"
						>
							La visibilidad sin estructura no posiciona.
						</p>
						<a href="/empresas" class="btn btn--outline"
							>Ver soluciones para empresas</a
						>
					</div>
				</article>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 5 — LÍNEAS DE SERVICIO -->
	<section class="servicios" aria-label="Líneas de servicio">
		<div class="container">
			<div class="servicios__header reveal">
				<span class="label">Lo que ofrecemos</span>
				<h2 class="display display--lg">
					Líneas de<br /><span class="gradient-text">servicio</span>
				</h2>
			</div>

			<div class="servicios__grid">
				<article class="servicio-card reveal">
					<div class="servicio-card__icon" aria-hidden="true">🎤</div>
					<h3 class="display display--sm servicio-card__title">
						Artistas musicales
					</h3>
					<p class="servicio-card__text">
						Impulsamos temas musicales y artistas que desean crecer
						con estrategia y estructura profesional.
					</p>
					<a
						href="/artistas"
						class="btn btn--primary servicio-card__btn"
						>Ver soluciones</a
					>
				</article>

				<article
					class="servicio-card servicio-card--magenta reveal reveal-delay-2"
				>
					<div class="servicio-card__icon" aria-hidden="true">🏢</div>
					<h3 class="display display--sm servicio-card__title">
						Marcas y negocios
					</h3>
					<p class="servicio-card__text">
						Acompañamos empresas que necesitan verse profesionales,
						atraer clientes y fortalecer su presencia digital.
					</p>
					<a
						href="/empresas"
						class="btn btn--outline servicio-card__btn"
						>Ver soluciones</a
					>
				</article>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 6 — CIERRE -->
	<section class="cierre" aria-label="Llamada a la acción final">
		<div class="container cierre__inner">
			<h2 class="display display--lg cierre__title reveal">
				Si vas a construir una marca,<br />
				<span class="gradient-text">hazlo con dirección.</span>
			</h2>
			<div class="reveal reveal-delay-2">
				<CTAWhatsApp />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* HERO */
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		align-items: flex-end;
		padding-top: 140px; /* header height — prevents content from going behind fixed nav on short viewports */
		padding-bottom: clamp(4rem, 8vw, 7rem);
		overflow: hidden;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
	}

	.hero__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background: none;
	}

	.hero__content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
		max-width: 780px;
		margin-left: 60%;
	}

	@media (max-width: 1500px) {
		.hero__content {
			margin-left: 45%;
		}
	}

	@media (max-width: 1280px) {
		.hero__content {
			margin-left: 38%;
		}
		.hero__title {
			line-height: 0.95;
		}
	}

	@media (max-width: 768px) {
		.hero__content {
			margin-left: 0;
			max-width: 100%;
		}
	}

	.hero__title {
		line-height: 0.92;
	}

	.hero__sub {
		color: var(--text-high);
		font-size: 1.55rem;
		max-width: 52ch;
		font-weight: 500;
	}

	.hero__ctas {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.5rem;
	}

	.hero__scroll {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-dim);
		margin-top: 1rem;
		transition: color var(--t-fast) var(--ease);
	}
	.hero__scroll:hover {
		color: var(--cyan);
	}

	.br-desktop {
		display: block;
	}

	/* IDENTIFICACIÓN */
	.identificacion {
		padding-block: var(--section-gap);
	}

	.identificacion__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.id-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition:
			border-color var(--t-med) var(--ease),
			transform var(--t-med) var(--ease);
	}
	.id-card:hover {
		border-color: var(--border-accent);
		transform: translateY(-4px);
	}
	.id-card--empresas:hover {
		border-color: var(--border-accent-magenta);
	}

	.id-card__image {
		position: relative;
		aspect-ratio: 4/3;
		overflow: hidden;
	}
	.id-card__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s var(--ease);
	}
	.id-card:hover .id-card__image img {
		transform: scale(1.04);
	}
	.id-card__image-overlay {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(to bottom, transparent 40%, var(--bg-card) 100%),
			linear-gradient(135deg, var(--cyan-dim) 0%, transparent 70%);
	}
	.id-card__image-overlay--magenta {
		background:
			linear-gradient(to bottom, transparent 40%, var(--bg-card) 100%),
			linear-gradient(135deg, var(--magenta-dim) 0%, transparent 70%);
	}

	.id-card__body {
		padding: clamp(1.5rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.id-card__icon {
		font-size: 1.8rem;
	}

	.id-card__title {
		color: var(--text-primary);
	}

	.id-card__text {
		color: var(--text-secondary);
		font-size: 1.14rem;
		line-height: 1.6;
		font-weight: 500;
	}
	.id-card__text strong {
		color: var(--text-primary);
		font-weight: 500;
	}

	.id-card__btn {
		margin-top: 0.5rem;
		align-self: flex-start;
	}

	/* QUÉ HACEMOS */
	.que-hacemos {
		padding-block: var(--section-gap);
		background: var(--bg-surface);
	}

	.que-hacemos__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(3rem, 6vw, 6rem);
		align-items: center;
	}

	.que-hacemos__text {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.que-hacemos__list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin-block: 0.5rem;
	}

	.que-hacemos__item {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		padding-block: 1rem;
		border-bottom: 1px solid var(--border);
		font-size: 1.14rem;
		color: var(--text-secondary);
		transition: color var(--t-fast) var(--ease);
		font-weight: 500;
	}
	.que-hacemos__item:hover {
		color: var(--text-primary);
	}

	.que-hacemos__num {
		font-family: var(--font-display);
		font-size: 0.9rem;
		color: var(--cyan);
		flex-shrink: 0;
		letter-spacing: 0.08em;
	}

	.que-hacemos__visual {
		position: relative;
	}

	.que-hacemos__img {
		width: 100%;
		border-radius: var(--radius-lg);
		display: block;
		position: relative;
		z-index: 1;
	}

	.que-hacemos__img-border {
		position: absolute;
		inset: -6px;
		border-radius: calc(var(--radius-lg) + 6px);
		background: linear-gradient(135deg, var(--cyan), var(--magenta));
		z-index: 0;
		opacity: 0.25;
		filter: blur(1px);
	}

	/* PROBLEMA */
	.problema {
		padding-block: var(--section-gap);
	}

	.problema__header {
		margin-bottom: clamp(2.5rem, 5vw, 4rem);
	}

	.problema__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.problema-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition: border-color var(--t-med) var(--ease);
	}
	.problema-card:hover {
		border-color: var(--border-accent);
	}
	.problema-card:last-child:hover {
		border-color: var(--border-accent-magenta);
	}

	.problema-card__image {
		position: relative;
		aspect-ratio: 16/9;
		overflow: hidden;
	}
	.problema-card__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.problema-card__badge {
		position: absolute;
		top: 1rem;
		left: 1rem;
		background: var(--cyan-dim);
		border: 1px solid var(--border-accent);
		color: var(--cyan);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.3rem 0.75rem;
		border-radius: 2px;
		backdrop-filter: blur(8px);
	}
	.problema-card__badge--magenta {
		background: var(--magenta-dim);
		border-color: var(--border-accent-magenta);
		color: var(--magenta);
	}

	.problema-card__body {
		padding: clamp(1.5rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.problema-card__list {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.problema-card__list li {
		font-size: 1.14rem;
		color: var(--text-secondary);
		padding-left: 1.2rem;
		position: relative;
		font-weight: 500;
	}
	.problema-card__list li::before {
		content: "·";
		position: absolute;
		left: 0;
		color: var(--cyan);
		font-weight: 700;
	}
	.problema-card:last-child .problema-card__list li::before {
		color: var(--magenta);
	}

	.problema-card__message {
		font-family: var(--font-display);
		font-size: 1.1rem;
		letter-spacing: 0.04em;
		color: var(--cyan);
		text-transform: uppercase;
		padding-top: 0.25rem;
	}
	.problema-card__message--magenta {
		color: var(--magenta);
	}

	/* SERVICIOS */
	.servicios {
		padding-block: var(--section-gap);
		background: var(--bg-surface);
	}

	.servicios__header {
		margin-bottom: clamp(2.5rem, 5vw, 4rem);
	}

	.servicios__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.servicio-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: clamp(2rem, 4vw, 3rem);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		transition:
			border-color var(--t-med) var(--ease),
			transform var(--t-med) var(--ease);
	}
	.servicio-card:hover {
		border-color: var(--border-accent);
		transform: translateY(-4px);
	}
	.servicio-card--magenta:hover {
		border-color: var(--border-accent-magenta);
	}

	.servicio-card__icon {
		font-size: 2.5rem;
	}

	.servicio-card__title {
		color: var(--text-primary);
	}

	.servicio-card__text {
		color: var(--text-secondary);
		font-size: 1.14rem;
		line-height: 1.7;
		flex: 1;
		font-weight: 500;
	}

	.servicio-card__btn {
		align-self: flex-start;
		margin-top: 0.5rem;
	}

	/* CIERRE */
	.cierre {
		padding-block: var(--section-gap);
		position: relative;
		overflow: hidden;
	}

	.cierre::before {
		content: "";
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 600px;
		height: 600px;
		background: radial-gradient(
			ellipse,
			var(--cyan-subtle) 0%,
			transparent 70%
		);
		pointer-events: none;
	}

	.cierre__inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 2.5rem;
	}

	.cierre__title {
		max-width: 18ch;
	}

	/* RESPONSIVE */
	@media (max-width: 900px) {
		.identificacion__grid,
		.problema__grid,
		.servicios__grid {
			grid-template-columns: 1fr;
		}

		.que-hacemos__inner {
			grid-template-columns: 1fr;
		}

		.que-hacemos__visual {
			order: -1;
		}
	}

