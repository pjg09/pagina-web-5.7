---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAWhatsApp from "../components/CTAWhatsApp.astro";
import { WHATSAPP_CTA } from "../data/constantes";
---

<BaseLayout
	title="Inicio"
	description="Desarrollamos identidad, narrativa y presencia para marcas y artistas que quieren crecer con estructura."
>
	<!--SECCIÓN 1 — HERO -->
	<section class="hero" aria-label="Hero principal">
		<div class="hero__bg">
			<img
				src="/images/HERO_PRINCIPAL_1.jpeg"
				alt="5.7 Onda Creativa Launch"
				class="hero__img"
				fetchpriority="high"
			/>
			<div class="hero__overlay"></div>
		</div>

		<div class="container hero__content">
			<h1 class="display display--xl hero__title reveal reveal-delay-1">
				ESTRUCTURA Y CRECIMIENTO PARA TU <span class="gradient-text"
					>MARCA</span
				> O TU <span class="gradient-text">MÚSICA</span>
			</h1>

			<p class="body--lg hero__sub reveal reveal-delay-2">
				Si eres artista o tienes un negocio, aquí encuentras dirección,
				estrategia y ejecución para avanzar correctamente.
			</p>
			<div class="hero__ctas reveal reveal-delay-3">
				<a href="/empresas" class="btn hero__btn-empresa">
					<img
						src="/images/BotonEmpresa.png"
						alt=""
						class="hero__btn-icon"
						aria-hidden="true"
					/>
					Soy empresa
				</a>
				<a href="/artistas" class="btn hero__btn-artista">
					<img
						src="/images/BotonArtista.png"
						alt=""
						class="hero__btn-icon"
						aria-hidden="true"
					/>
					Soy artista
				</a>
			</div>

			<a
				href="#metodo"
				class="hero__scroll reveal reveal-delay-4"
				aria-label="Ver cómo trabajamos"
			>
				<span>Conocer cómo trabajamos</span>
				<svg
					width="16"
					height="16"
					viewBox="0 0 16 16"
					fill="none"
					aria-hidden="true"
				>
					<path
						d="M8 3v10M3 8l5 5 5-5"
						stroke="currentColor"
						stroke-width="1.5"
						stroke-linecap="round"
						stroke-linejoin="round"></path>
				</svg>
			</a>
		</div>
	</section>

	<!-- SECCIÓN 2 — IDENTIFICACIÓN RÁPIDA -->
	<section
		class="identificacion"
		id="metodo"
		aria-label="Para artistas y empresas"
	>
		<div class="container">
			<div class="identificacion__grid">
				<!-- Empresas -->
				<article
					class="id-card id-card--empresas reveal reveal-delay-2"
				>
					<div class="id-card__image">
						<img
							src="/images/Empresas01.jpeg"
							alt="Equipo de trabajo en agencia"
							loading="lazy"
						/>
						<div
							class="id-card__image-overlay id-card__image-overlay--magenta"
						>
						</div>
					</div>
					<div class="id-card__body">
						<span class="id-card__icon" aria-hidden="true">🏢</span>
						<h2 class="display display--sm id-card__title">
							MARCAS
						</h2>
						<p class="id-card__text">
							Tienes un negocio en marcha. Estás vendiendo,
							moviéndote o buscando crecer. Pero sabes que tu
							presencia digital puede mejorar: verse más
							profesional, atraer más clientes y generar
							resultados reales. Algunas marcas no han empezado
							bien. Otras ya están… pero no están aprovechando su
							potencial. <br /><br />
							<strong
								>Aquí es donde se marca la diferencia.</strong
							>
						</p>
						<div
							class="divider"
							style="background: linear-gradient(90deg, var(--magenta), var(--cyan));"
						>
						</div>
						<a
							href="/empresas"
							class="btn btn--outline id-card__btn"
							>QUIERO FORTALECER MI MARCA</a
						>
					</div>
				</article>

				<!-- Artistas -->
				<article class="id-card id-card--artistas reveal">
					<div class="id-card__image">
						<img
							src="/images/Artistas01.jpeg"
							alt="Artista trabajando en estudio"
							loading="lazy"
						/>
						<div class="id-card__image-overlay"></div>
					</div>
					<div class="id-card__body">
						<span class="id-card__icon" aria-hidden="true">🎤</span>
						<h2 class="display display--sm id-card__title">
							ARTISTAS
						</h2>
						<p class="id-card__text">
							Eres artista y tienes música en movimiento. Estás
							creando, lanzando o preparándote para hacerlo. Pero
							sabes que puedes hacerlo mejor: con más impacto, más
							alcance y una dirección clara. Algunos no saben por
							dónde empezar. Otros ya están activos… pero quieren
							crecer de verdad. <br /><br /><br />
							<strong>Aquí es donde todo cambia.</strong>
						</p>
						<div class="divider"></div>
						<a
							href="/artistas"
							class="btn btn--primary id-card__btn"
							>QUIERO IMPULSAR MI MÚSICA</a
						>
					</div>
				</article>
			</div>

			<div class="id-frase reveal">
				<p class="id-frase__texto">
					<span class="gradient-text"
						>NO IMPORTA EN QUÉ PUNTO ESTÉS.<br />
						LO IMPORTANTE ES TENER DIRECCIÓN PARA EL SIGUIENTE NIVEL.</span
					>
				</p>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 3 — QUÉ HACEMOS -->
	<section class="que-hacemos" aria-label="Qué hacemos">
		<div class="container">
			<div class="que-hacemos__inner">
				<div class="que-hacemos__text">
					<span class="label reveal">Nuestro enfoque</span>
					<h2 class="display display--lg reveal reveal-delay-1">
						Qué<br /><span class="gradient-text">hacemos</span>
					</h2>
					<p class="que-hacemos__subtitulo reveal reveal-delay-1">
						Esto es lo que hacemos cuando hay dirección:
					</p>
					<ul class="que-hacemos__list">
						<li class="que-hacemos__item reveal reveal-delay-1">
							<span class="que-hacemos__num">01</span>
							<p>Construimos estructura digital.</p>
						</li>
						<li class="que-hacemos__item reveal reveal-delay-2">
							<span class="que-hacemos__num">02</span>
							<p>Ejecutamos visibilidad estratégica.</p>
						</li>
						<li class="que-hacemos__item reveal reveal-delay-3">
							<span class="que-hacemos__num">03</span>
							<p>Producimos imagen profesional.</p>
						</li>
						<li class="que-hacemos__item reveal reveal-delay-4">
							<span class="que-hacemos__num">04</span>
							<p>Acompañamos crecimiento real.</p>
						</li>
					</ul>
				</div>

				<div class="que-hacemos__visual reveal reveal-delay-2">
					<img
						src="/images/_04.jpeg"
						alt="Equipo de producción digital"
						loading="lazy"
						class="que-hacemos__img"
					/>
					<div class="que-hacemos__img-border"></div>
				</div>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 4 — EL PROBLEMA QUE RESOLVEMOS -->
	<section class="problema" aria-label="El problema que resolvemos">
		<div class="container">
			<div class="problema__header reveal">
				<span class="label">DONDE MUCHOS SE ESTANCAN</span>
				<h2 class="display display--lg">
					¿Te suena<br /><span class="gradient-text">familiar?</span>
				</h2>
			</div>

			<div class="problema__grid">
				<!-- Empresas -->
				<div class="problema-card-outer reveal reveal-delay-2">
					<div
						class="problema-card__badge problema-card__badge--magenta"
					>
						Empresas
					</div>
					<article class="problema-card">
						<div class="problema-card__image">
							<img
								src="/images/Empresas02.jpeg"
								alt="Empresa sin presencia digital estructurada"
								loading="lazy"
							/>
						</div>
						<div class="problema-card__body">
							<p
								class="problema-card__subtitulo problema-card__subtitulo--magenta"
							>
								ESTO ES LO QUE ESTÁ LIMITANDO LOS RESULTADOS DE
								TU MARCA:
							</p>
							<ul class="problema-card__list">
								<li>
									Tienes presencia digital, pero sin
									estructura
								</li>
								<li>Publicas sin una estrategia clara</li>
								<li>
									No logras diferenciarte ni generar autoridad
								</li>
								<li>No conviertes tu contenido en clientes</li>
								<li>
									No estás aprovechando todo el potencial
									digital
								</li>
							</ul>
							<p
								class="problema-card__message problema-card__message--magenta"
							>
								ESTAR EN DIGITAL NO ES SUFICIENTE. HAY QUE SABER
								CÓMO CONVERTIRLO EN RESULTADOS.
							</p>
							<a href="/empresas" class="btn btn--outline"
								>Ver cómo fortalecer mi marca</a
							>
						</div>
					</article>
				</div>

				<!-- Artistas -->
				<div class="problema-card-outer reveal">
					<div class="problema-card__badge">Artistas</div>
					<article class="problema-card">
						<div class="problema-card__image">
							<img
								src="/images/Artistas02.jpeg"
								alt="Artista sin visibilidad digital"
								loading="lazy"
							/>
						</div>
						<div class="problema-card__body">
							<p class="problema-card__subtitulo">
								ESTO ES LO QUÉ ESTÁ ENFRENTANDO EL CRECIMIENTO
								DE TU MÚSICA:
							</p>
							<ul class="problema-card__list">
								<li>Lanzas música sin una estructura clara</li>
								<li>No logras el alcance que esperas</li>
								<li>No sabes cómo escalar tus resultados</li>
								<li>
									Dependes solo de subir contenido sin
									estrategia
								</li>
								<li>
									No tienen un plan sólido detrás de cada
									lanzamiento
								</li>
							</ul>
							<p class="problema-card__message">
								EL TALENTO NO ES EL PROBLEMA. LA FALTA DE
								DIRECCIÓN SÍ.
							</p>
							<a href="/artistas" class="btn btn--primary"
								>Ver cómo posicionar mi música</a
							>
						</div>
					</article>
				</div>
			</div>
		</div>
	</section>

	<!-- SECCIÓN 5 — LÍNEAS DE SERVICIO -->
	<section class="servicios" aria-label="Líneas de servicio">
		<div class="container">
			<div class="servicios__header reveal">
				<span class="label">Lo que ofrecemos</span>
				<h2 class="display display--lg">
					Líneas de<br /><span class="gradient-text">servicio</span>
				</h2>
			</div>

			<div class="servicios__grid">
				<article
					class="servicio-card servicio-card--magenta reveal reveal-delay-2"
				>
					<h3 class="display display--sm servicio-card__title">
						Marcas y negocios
					</h3>
					<p class="servicio-card__text">
						Acompañamos empresas que necesitan verse profesionales,
						atraer clientes y fortalecer su presencia digital.
					</p>
					<a
						href="/empresas"
						class="btn servicio-card__btn servicio-card__btn--empresas"
						>Ver soluciones</a
					>
				</article>

				<article class="servicio-card reveal">
					<h3 class="display display--sm servicio-card__title">
						Artistas musicales
					</h3>
					<p class="servicio-card__text">
						Impulsamos temas musicales y artistas que desean crecer
						con estrategia y estructura profesional.
					</p>
					<a
						href="/artistas"
						class="btn servicio-card__btn servicio-card__btn--artistas"
						>Ver soluciones</a
					>
				</article>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<!-- SECCIÓN 6 — CIERRE -->
	<section class="cierre" aria-label="Llamada a la acción final">
		<div class="container cierre__inner">
			<h2 class="display display--lg cierre__title reveal">
				Si vas a construir una marca,<br />
				<span class="gradient-text">hazlo con dirección.</span>
			</h2>
			<div class="reveal reveal-delay-2">
				<CTAWhatsApp />
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* HERO */
	.hero {
		position: relative;
		min-height: 100svh;
		display: flex;
		align-items: flex-end;
		padding-top: 140px; /* header height — prevents content from going behind fixed nav on short viewports */
		padding-bottom: clamp(4rem, 8vw, 7rem);
		overflow: hidden;
	}

	.hero__bg {
		position: absolute;
		inset: 0;
	}

	.hero__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background: none;
	}

	.hero__content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.5rem;
		max-width: 780px;
		margin-left: 60%;
	}

	@media (max-width: 1500px) {
		.hero__content {
			margin-left: 45%;
		}
	}

	@media (max-width: 1280px) {
		.hero__content {
			margin-left: 38%;
		}
		.hero__title {
			line-height: 0.95;
		}
	}

	@media (max-width: 768px) {
		.hero__content {
			margin-left: 0;
			max-width: 100%;
		}
	}

	.hero__title {
		line-height: 0.92;
	}

	.hero__sub {
		color: var(--text-high);
		font-size: 1.8rem;
		max-width: 52ch;
		font-weight: 500;
	}

	.hero__ctas {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.5rem;
	}

	.hero__btn-artista,
	.hero__btn-empresa {
		background: #fff;
		color: #000;
		border: none;
	}

	.hero__btn-artista:hover,
	.hero__btn-empresa:hover {
		background: #fff;
		border: 2px solid var(--cyan);
		transform: translateY(-2px);
		background-clip: text;
		-webkit-background-clip: text;
		color: transparent;
		background-image: linear-gradient(90deg, var(--cyan), var(--magenta));
	}

	.hero__btn-icon {
		width: 22px;
		height: 22px;
		object-fit: contain;
		flex-shrink: 0;
	}

	.hero__scroll {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-dim);
		margin-top: 1rem;
		transition: color var(--t-fast) var(--ease);
	}
	.hero__scroll:hover {
		color: var(--cyan);
	}

	.br-desktop {
		display: block;
	}

	/* IDENTIFICACIÓN */
	.identificacion {
		padding-block: var(--section-gap);
	}

	.identificacion__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.id-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		overflow: hidden;
		transition:
			border-color var(--t-med) var(--ease),
			transform var(--t-med) var(--ease);
	}
	.id-card:hover {
		border-color: var(--border-accent);
		transform: translateY(-4px);
	}
	.id-card--empresas:hover {
		border-color: var(--border-accent-magenta);
	}

	.id-card__image {
		position: relative;
		aspect-ratio: 4/3;
		overflow: hidden;
	}
	.id-card__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s var(--ease);
	}
	.id-card:hover .id-card__image img {
		transform: scale(1.04);
	}
	.id-card__image-overlay {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(to bottom, transparent 40%, var(--bg-card) 100%),
			linear-gradient(135deg, var(--cyan-dim) 0%, transparent 70%);
	}
	.id-card__image-overlay--magenta {
		background:
			linear-gradient(to bottom, transparent 40%, var(--bg-card) 100%),
			linear-gradient(135deg, var(--magenta-dim) 0%, transparent 70%);
	}

	.id-card__body {
		padding: clamp(1.5rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.id-card__icon {
		font-size: 1.8rem;
	}

	.id-card__title {
		color: var(--text-primary);
	}

	.id-card__text {
		color: var(--text-secondary);
		font-size: 1.14rem;
		line-height: 1.6;
		font-weight: 500;
	}
	.id-card__text strong {
		color: var(--text-primary);
		font-weight: 500;
	}

	.id-card__btn {
		margin-top: 0.5rem;
		align-self: flex-start;
	}

	/* FRASE — debajo de las tarjetas */
	.id-frase {
		margin-top: 2.5rem;
		padding: 1.25rem 2rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		background: var(--bg-surface);
		text-align: center;
	}

	.id-frase__texto {
		font-family: var(--font-display);
		font-size: clamp(1rem, 2.2vw, 1.45rem);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-secondary);
		line-height: 1.5;
	}

	/* QUÉ HACEMOS */
	.que-hacemos {
		padding-block: var(--section-gap);
		background: var(--bg-surface);
	}

	.que-hacemos__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(3rem, 6vw, 6rem);
		align-items: center;
	}

	.que-hacemos__text {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.que-hacemos__subtitulo {
		font-size: 1.2rem;
		font-weight: 500;
		color: var(--cyan);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding-left: 1rem;
		border-left: 2px solid var(--cyan);
		margin-top: -0.5rem;
	}

	.que-hacemos__list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin-block: 0.5rem;
	}

	.que-hacemos__item {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		padding-block: 1rem;
		border-bottom: 1px solid var(--border);
		font-size: 1.37rem;
		color: var(--text-secondary);
		transition: color var(--t-fast) var(--ease);
		font-weight: 500;
	}
	.que-hacemos__item:hover {
		color: var(--text-primary);
	}

	.que-hacemos__num {
		font-family: var(--font-display);
		font-size: 0.9rem;
		color: var(--cyan);
		flex-shrink: 0;
		letter-spacing: 0.08em;
	}

	.que-hacemos__visual {
		position: relative;
		transform: scale(1.3);
		transform-origin: left center;
	}

	.que-hacemos__inner .que-hacemos__visual.visible {
		transform: scale(1.5);
	}

	.que-hacemos__img {
		width: 100%;
		border-radius: var(--radius-lg);
		display: block;
		position: relative;
		z-index: 1;
	}

	.que-hacemos__img-border {
		position: absolute;
		inset: -6px;
		border-radius: calc(var(--radius-lg) + 6px);
		background: linear-gradient(135deg, var(--cyan), var(--magenta));
		z-index: 0;
		opacity: 0.25;
		filter: blur(1px);
	}

	/* PROBLEMA */
	.problema {
		padding-block: var(--section-gap);
	}

	.problema__header {
		margin-bottom: clamp(2.5rem, 5vw, 4rem);
	}

	.problema__header .label {
		font-size: 0.91rem;
	}

	.problema__grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	.problema-card-outer {
		display: flex;
		flex-direction: column;
	}

	.problema-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 0;
		transition: border-color var(--t-med) var(--ease);
		overflow: hidden;
	}
	.problema-card-outer:hover .problema-card {
		border-color: var(--border-accent);
	}
	.problema-card-outer:last-child:hover .problema-card {
		border-color: var(--border-accent-magenta);
	}

	.problema-card__image {
		position: relative;
		aspect-ratio: 16/9;
		overflow: hidden;
	}
	.problema-card__image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.problema-card__badge {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		background: var(--cyan-dim);
		border: 1px solid var(--border-accent);
		border-bottom: none;
		color: var(--cyan);
		font-size: 0.95rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		padding: 0.55rem 1.4rem;
